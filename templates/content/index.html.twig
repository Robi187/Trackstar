{% extends 'base.html.twig' %}

{% block body %}
	{{ parent() }}

	<style>
		@import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap');

		body {
			background: #0a0a0a;
			color: white;
			font-family: 'DM Sans', sans-serif;
		}

		.page-wrapper {
			display: flex;
			justify-content: center;
			align-items: flex-start;
			padding: 60px 20px;
			gap: 24px;
		}

		/* ── LEFT PANEL ── */
		.left-panel {
			width: 320px;
			background: #161616;
			border-radius: 16px;
			overflow: hidden;
			border: 1px solid #2a2a2a;
		}

		.cover-wrapper {
			position: relative;
			width: 100%;
			aspect-ratio: 1;
			overflow: hidden;
		}

		.cover-wrapper img,
		.cover-placeholder {
			width: 100%;
			height: 100%;
			object-fit: cover;
			display: block;
		}

		.cover-placeholder {
			background: #1e1e1e;
			display: flex;
			align-items: center;
			justify-content: center;
			font-size: 72px;
		}

		.play-overlay {
			position: absolute;
			inset: 0;
			display: flex;
			align-items: center;
			justify-content: center;
			background: rgba(0, 0, 0, 0.35);
			opacity: 0;
			transition: opacity 0.2s;
		}

		.cover-wrapper:hover .play-overlay {
			opacity: 1;
		}

		.play-circle {
			width: 64px;
			height: 64px;
			border-radius: 50%;
			background: #e63946;
			border: none;
			cursor: pointer;
			display: flex;
			align-items: center;
			justify-content: center;
			font-size: 22px;
			color: white;
			transition: transform 0.15s;
			box-shadow: 0 4px 20px rgba(230, 57, 70, 0.5);
		}

		.play-circle:hover {
			transform: scale(1.08);
		}

		.track-meta {
			padding: 18px 20px 8px;
		}

		.track-meta h2 {
			margin: 0 0 4px;
			font-size: 18px;
			font-weight: 700;
			white-space: nowrap;
			overflow: hidden;
			text-overflow: ellipsis;
		}

		.track-meta .artist {
			color: #e63946;
			font-size: 14px;
			margin: 0;
		}

		/* Waveform */
		.waveform-wrap {
			margin: 14px 20px;
			cursor: pointer;
		}

		/* Social row */
		.social-row {
			display: flex;
			align-items: center;
			gap: 20px;
			padding: 14px 20px;
			border-top: 1px solid #2a2a2a;
		}

		.social-btn {
			display: flex;
			align-items: center;
			gap: 6px;
			background: none;
			border: none;
			color: #aaa;
			font-size: 13px;
			cursor: pointer;
			font-family: inherit;
			transition: color 0.15s;
			padding: 0;
		}

		.social-btn:hover { color: #e63946; }
		.social-btn:hover svg { fill: #e63946; }

		.social-btn svg {
			width: 18px;
			height: 18px;
			fill: #aaa;
			transition: fill 0.15s;
		}

		.social-btn.liked svg { fill: #e63946; }
		.social-btn.liked { color: #e63946; }

		/* Divider between social buttons */
		.social-divider {
			width: 1px;
			height: 18px;
			background: #2a2a2a;
		}

		.download-btn-right {
			display: flex;
			align-items: center;
			justify-content: center;
			gap: 10px;
			padding: 16px;
			background: #e63946;
			color: white;
			border-radius: 12px;
			font-size: 16px;
			font-weight: 600;
			text-decoration: none;
			transition: background 0.15s, transform 0.1s;
		}

		.download-btn-right:hover {
			background: #c1121f;
			transform: translateY(-1px);
		}

		.download-btn-right svg {
			width: 18px;
			height: 18px;
			fill: white;
		}

		/* Info table */
		.info-table {
			border-top: 1px solid #2a2a2a;
			padding: 16px 20px 20px;
		}

		.info-row {
			display: flex;
			justify-content: space-between;
			align-items: center;
			padding: 8px 0;
			font-size: 13px;
			border-bottom: 1px solid #1f1f1f;
		}

		.info-row:last-child { border-bottom: none; }
		.info-row .label { color: #666; }
		.info-row .value { color: #ddd; font-weight: 500; }

		/* ── RIGHT PANEL ── */
		.right-panel {
			width: 420px;
			display: flex;
			flex-direction: column;
			gap: 16px;
		}

		.panel-box {
			background: #161616;
			border-radius: 16px;
			border: 1px solid #2a2a2a;
			padding: 24px;
		}

		.panel-box h3 {
			margin: 0 0 18px;
			font-size: 17px;
			font-weight: 700;
			color: #fff;
			letter-spacing: 0.02em;
		}

		/* Description box */
		.description-text {
			font-size: 14px;
			line-height: 1.7;
			color: #bbb;
			margin: 0 0 16px;
		}

		.meta-line {
			font-size: 13px;
			color: #888;
			margin-bottom: 12px;
		}

		.meta-line b { color: #ccc; }

		.tag-list {
			display: flex;
			flex-wrap: wrap;
			gap: 6px;
			margin-top: 4px;
		}

		.tag-badge {
			border: 1px solid #e63946;
			color: #e63946;
			border-radius: 6px;
			padding: 4px 12px;
			font-size: 12px;
			font-weight: 500;
			letter-spacing: 0.02em;
		}

		/* Rating box */
		.rating-box {
			display: flex;
			align-items: center;
			gap: 10px;
		}

		.stars {
			display: flex;
			gap: 4px;
		}

		.stars svg {
			width: 26px;
			height: 26px;
		}

		.star-filled { fill: #f5a623; }
		.star-empty { fill: none; stroke: #f5a623; stroke-width: 1.5; }

		.rating-score {
			font-size: 22px;
			font-weight: 700;
			color: #f5a623;
		}

		.rating-max {
			font-size: 14px;
			color: #666;
		}

		.report-overlay {
			display: none; position: fixed; inset: 0;
			background: rgba(0,0,0,0.7); backdrop-filter: blur(4px);
			z-index: 1000; align-items: center; justify-content: center;
		}
		.report-overlay.open { display: flex; }
		.report-modal {
			background: #1a1a1a; border: 1px solid #2e2e2e;
			border-radius: 16px; padding: 28px; width: 380px;
			box-shadow: 0 24px 60px rgba(0,0,0,0.6);
			animation: modalIn .2s ease;
		}
		@keyframes modalIn {
			from { opacity: 0; transform: translateY(-12px) scale(0.97); }
			to   { opacity: 1; transform: translateY(0) scale(1); }
		}
		.report-modal-title { font-size: 16px; font-weight: 700; color: #fff; margin: 0 0 4px; }
		.report-modal-sub   { font-size: 13px; color: #666; margin: 0 0 20px; }
		.report-label { font-size: 12px; color: #888; margin-bottom: 6px; display: block; letter-spacing: 0.03em; }

		.report-presets { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 16px; }
		.report-preset {
			padding: 9px 10px; border-radius: 10px;
			border: 1px solid #2c2c2c; background: #141414;
			color: #888; font-size: 12px; font-weight: 500;
			cursor: pointer; text-align: center; font-family: inherit;
			transition: all .15s;
		}
		.report-preset:hover,
		.report-preset.selected { border-color: #e63946; color: #e63946; background: rgba(230,57,70,0.08); }

		.report-textarea {
			width: 100%; background: #141414; border: 1px solid #2c2c2c;
			border-radius: 8px; color: #fff; font-size: 13px;
			padding: 10px 12px; outline: none; font-family: inherit;
			resize: vertical; min-height: 80px; box-sizing: border-box;
			transition: border-color .15s; margin-bottom: 16px;
		}
		.report-textarea:focus { border-color: #e63946; }

		.report-modal-actions { display: flex; gap: 8px; }
		.report-cancel {
			flex: 1; padding: 10px; border-radius: 8px;
			border: 1px solid #2c2c2c; background: transparent;
			color: #666; font-size: 13px; font-weight: 500;
			cursor: pointer; font-family: inherit; transition: all .15s;
		}
		.report-cancel:hover { border-color: #444; color: #aaa; }
		.report-confirm {
			flex: 1; padding: 10px; border-radius: 8px;
			border: 1px solid rgba(230,57,70,0.5); background: rgba(230,57,70,0.12);
			color: #e63946; font-size: 13px; font-weight: 600;
			cursor: pointer; font-family: inherit; transition: all .15s;
		}
		.report-confirm:hover { background: rgba(230,57,70,0.22); border-color: #e63946; }
		.report-confirm:disabled { opacity: 0.4; cursor: not-allowed; }

		.report-feedback {
			font-size: 13px; text-align: center; padding: 10px;
			border-radius: 8px; margin-bottom: 12px; display: none;
		}
		.report-feedback.success { background: rgba(0,200,80,.10); color: #00d966; border: 1px solid rgba(0,200,80,.3); }
		.report-feedback.error   { background: rgba(224,36,52,.12); color: #ff6070; border: 1px solid rgba(224,36,52,.4); }
	</style>

	<div class="page-wrapper">

		<!-- LEFT PANEL -->
		<div class="left-panel">

			<div class="cover-wrapper">
				{% if content.imageFile %}
					<img src="{{ asset(content.imageFile) }}" alt="{{ content.title }}"/>
				{% else %}
					<div class="cover-placeholder">&#127925;</div>
				{% endif %}
				{% if 'soundkit' not in content.type.name|lower and 'sound kit' not in content.type.name|lower %}
				<div class="play-overlay">
					<button class="play-circle" id="play-btn">▶</button>
				</div>
				{% endif %}
			</div>

			<div class="track-meta">
				<h2>{{ content.title }}</h2>
				{% if content.fkUser %}
					<a href="{{ path('app_userprofile', { username: content.fkUser.username }) }}" class="artist">
						{{ content.fkUser.username }}
					</a>
				{% else %}
					<span class="artist">Unknown</span>
				{% endif %}
			</div>

			{% if 'soundkit' not in content.type.name|lower and 'sound kit' not in content.type.name|lower %}
			<div class="waveform-wrap">
				<div id="waveform"></div>
			</div>
			{% endif %}

			<div class="social-row">
				<!-- Likes -->
				<button class="social-btn {{ isFavorited ? 'liked' : '' }}" id="fav-btn" data-content-id="{{ content.id }}">
					<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" id="fav-icon">
						{% if isFavorited %}
							<path fill="#e63946" d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
						{% else %}
							<path fill="none" stroke="#aaa" stroke-width="2" d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
						{% endif %}
					</svg>
					<span id="fav-count">{{ favoriteCount }}</span>
				</button>

				<div class="social-divider"></div>

				<!-- Downloads -->
				<span class="social-btn">
					<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
						<path d="M12 16l-5-5h3.5V4h3v7H17l-5 5zm-7 2h14v2H5v-2z"/>
					</svg>
					{{ content.downloadCount }}
				</span>
			</div>

			<div class="info-table">
				<div class="info-row">
					<span class="label">Kategorie</span>
					<span class="value">{{ content.type.name }}</span>
				</div>
			</div>

		</div>

		<!-- RIGHT PANEL -->
		<div class="right-panel">

			<a href="{{ path('content_download', { id: content.id }) }}" class="download-btn-right">
				<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
					<path d="M12 16l-5-5h3.5V4h3v7H17l-5 5zm-7 2h14v2H5v-2z"/>
				</svg>
				Download
			</a>

			<!-- Description + Tags -->
			<div class="panel-box">
				<h3>Informationen</h3>
				<p class="description-text">{{ content.description }}</p>

				<div class="meta-line">
					<b>Tags</b>
				</div>
				<div class="tag-list">
					{% for tag in tags %}
						<span class="tag-badge">{{ tag.fkTag.name }}</span>
					{% endfor %}
				</div>
			</div>

			<!-- Rating -->
			<div class="panel-box">
				<h3>Bewertung</h3>
				<div class="rating-box">
					<div class="stars">
						{% for i in 1..5 %}
							{% if averageRating >= i %}
								<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
									<polygon class="star-filled" points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/>
								</svg>
							{% elseif averageRating >= i - 0.5 %}
								<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
									<defs>
										<linearGradient id="half{{ i }}">
											<stop offset="50%" stop-color="#f5a623"/>
											<stop offset="50%" stop-color="transparent"/>
										</linearGradient>
									</defs>
									<polygon fill="url(#half{{ i }})" stroke="#f5a623" stroke-width="1.5" points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/>
								</svg>
							{% else %}
								<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
									<polygon class="star-empty" points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/>
								</svg>
							{% endif %}
						{% endfor %}
					</div>
					<span class="rating-score">{{ averageRating|number_format(1) }}</span>
					<span class="rating-max">/ 5.0</span>
				</div>
			</div>
			<div class="social-divider"></div>

			<button class="social-btn" id="report-btn">
				<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
					<path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/>
					<line x1="4" y1="22" x2="4" y2="15" stroke-width="2" stroke-linecap="round"/>
				</svg>
				Melden
			</button>
		</div>
	</div>

	<script>
		(function () {
			const btn   = document.getElementById('fav-btn');
			const count = document.getElementById('fav-count');
			const icon  = document.getElementById('fav-icon');
			if (!btn) return;

			const filledPath = 'M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z';

			btn.addEventListener('click', async function () {
				const id  = btn.dataset.contentId;
				const res = await fetch('/favoriten/toggle/' + id, {
					method: 'POST',
					headers: { 'X-Requested-With': 'XMLHttpRequest' },
				});
				if (!res.ok) return;
				const data = await res.json();

				count.textContent = data.count;
				btn.classList.toggle('liked', data.favorited);

				const path = icon.querySelector('path');
				if (data.favorited) {
					path.setAttribute('fill', '#e63946');
					path.removeAttribute('stroke');
					path.removeAttribute('stroke-width');
				} else {
					path.setAttribute('fill', 'none');
					path.setAttribute('stroke', '#aaa');
					path.setAttribute('stroke-width', '2');
				}
			});
		})();
	</script>

	{% if 'soundkit' not in content.type.name|lower and 'sound kit' not in content.type.name|lower %}
	<script type="module">
		import WaveSurfer from 'https://unpkg.com/wavesurfer.js@7/dist/wavesurfer.esm.js';

		const btn = document.getElementById('play-btn');

		const ws = WaveSurfer.create({
			container: '#waveform',
			url: '{{ asset('uploads/' ~ content.filePath) }}',
			waveColor: '#3a3a3a',
			progressColor: '#e63946',
			height: 40,
			barWidth: 2,
			barGap: 2,
			barRadius: 2,
			cursorColor: '#e63946',
			cursorWidth: 2,
			interact: true,
		});

		btn.addEventListener('click', () => ws.playPause());

		ws.on('play',   () => { btn.textContent = '⏸'; });
		ws.on('pause',  () => { btn.textContent = '▶'; });
		ws.on('finish', () => { btn.textContent = '▶'; });
	</script>
	{% endif %}
	<div class="report-overlay" id="reportOverlay" onclick="closeReportModal(event)">
    <div class="report-modal">
        <div class="report-modal-title">Inhalt melden</div>
        <div class="report-modal-sub">Was stimmt mit diesem Inhalt nicht?</div>

        <span class="report-label">Grund *</span>
        <div class="report-presets">
            {% for reason in reasons %}
                <button class="report-preset"
                        data-id="{{ reason.id }}"
                        onclick="selectReason(this, {{ reason.id }})">
                    {{ reason.name }}
                </button>
            {% endfor %}
        </div>

        <span class="report-label">Zusätzliche Nachricht (optional)</span>
        <textarea class="report-textarea" id="reportMessage"
                  placeholder="Beschreibe das Problem genauer …"></textarea>

        <div class="report-feedback" id="reportFeedback"></div>

        <div class="report-modal-actions">
            <button class="report-cancel" onclick="closeReportModalDirect()">Abbrechen</button>
            <button class="report-confirm" id="reportSubmit" onclick="submitReport()">Melden</button>
        </div>
    </div>
</div>

<script>
    let selectedReasonId = null;

    document.getElementById('report-btn').addEventListener('click', () => {
        document.getElementById('reportOverlay').classList.add('open');
    });

    function closeReportModal(e) {
        if (e.target === document.getElementById('reportOverlay')) closeReportModalDirect();
    }

    function closeReportModalDirect() {
        document.getElementById('reportOverlay').classList.remove('open');
        document.getElementById('reportFeedback').style.display = 'none';
        document.getElementById('reportFeedback').className = 'report-feedback';
        document.getElementById('reportMessage').value = '';
        document.getElementById('reportSubmit').disabled = false;
        document.querySelectorAll('.report-preset').forEach(b => b.classList.remove('selected'));
        selectedReasonId = null;
    }

    function selectReason(el, id) {
        document.querySelectorAll('.report-preset').forEach(b => b.classList.remove('selected'));
        el.classList.add('selected');
        selectedReasonId = id;
    }

    async function submitReport() {
        if (!selectedReasonId) {
            showReportFeedback('error', 'Bitte wähle einen Grund aus.');
            return;
        }

        document.getElementById('reportSubmit').disabled = true;

        const form = new FormData();
        form.append('reason_id', selectedReasonId);
        form.append('message', document.getElementById('reportMessage').value.trim());

        const res = await fetch('/content/{{ content.id }}/melden', {
            method: 'POST',
            body: form
        });
        const data = await res.json();

        if (res.ok) {
            showReportFeedback('success', 'Danke! Der Inhalt wurde gemeldet.');
            setTimeout(closeReportModalDirect, 1100);
        } else if (res.status === 409) {
            showReportFeedback('error', 'Du hast diesen Inhalt bereits gemeldet.');
        } else if (res.status === 401) {
            showReportFeedback('error', 'Du musst eingeloggt sein um zu melden.');
            document.getElementById('reportSubmit').disabled = false;
        } else {
            showReportFeedback('error', data.error ?? 'Fehler beim Senden.');
            document.getElementById('reportSubmit').disabled = false;
        }
    }

    function showReportFeedback(type, msg) {
        const el = document.getElementById('reportFeedback');
        el.textContent = msg;
        el.className = 'report-feedback ' + type;
        el.style.display = 'block';
    }

    document.addEventListener('keydown', e => {
        if (e.key === 'Escape') closeReportModalDirect();
    });
</script>
{% endblock %}
