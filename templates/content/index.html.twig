{% extends 'base.html.twig' %}

{% block body %}
	{{ parent() }}

	<style>
		@import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap');

		body {
			background: #0a0a0a;
			color: white;
			font-family: 'DM Sans', sans-serif;
		}

		.content-outer {
			max-width: 764px;
			margin: 0 auto;
			padding: 60px 20px 0;
			box-sizing: border-box;
		}

		.page-wrapper {
			display: flex;
			align-items: flex-start;
			gap: 24px;
			margin-bottom: 32px;
		}

		/* ── LEFT PANEL ── */
		.left-panel {
			width: 320px;
			background: #161616;
			border-radius: 16px;
			overflow: hidden;
			border: 1px solid #2a2a2a;
		}

		.cover-wrapper {
			position: relative;
			width: 100%;
			aspect-ratio: 1;
			overflow: hidden;
		}

		.cover-wrapper img,
		.cover-placeholder {
			width: 100%;
			height: 100%;
			object-fit: cover;
			display: block;
		}

		.cover-placeholder {
			background: #1e1e1e;
			display: flex;
			align-items: center;
			justify-content: center;
			font-size: 72px;
		}

		.play-overlay {
			position: absolute;
			inset: 0;
			display: flex;
			align-items: center;
			justify-content: center;
			background: rgba(0, 0, 0, 0.35);
			opacity: 0;
			transition: opacity 0.2s;
		}

		.cover-wrapper:hover .play-overlay {
			opacity: 1;
		}

		.play-circle {
			width: 64px;
			height: 64px;
			border-radius: 50%;
			background: #e63946;
			border: none;
			cursor: pointer;
			display: flex;
			align-items: center;
			justify-content: center;
			font-size: 22px;
			color: white;
			transition: transform 0.15s;
			box-shadow: 0 4px 20px rgba(230, 57, 70, 0.5);
		}

		.play-circle:hover {
			transform: scale(1.08);
		}

		.track-meta {
			padding: 18px 20px 8px;
		}

		.track-meta h2 {
			margin: 0 0 4px;
			font-size: 18px;
			font-weight: 700;
			white-space: nowrap;
			overflow: hidden;
			text-overflow: ellipsis;
		}

		.track-meta .artist {
			color: #e63946;
			font-size: 14px;
			margin: 0;
		}

		/* Waveform */
		.waveform-wrap {
			margin: 14px 20px;
			cursor: pointer;
		}

		/* Social row */
		.social-row {
			display: flex;
			align-items: center;
			gap: 20px;
			padding: 14px 20px;
			border-top: 1px solid #2a2a2a;
		}

		.social-btn {
			display: flex;
			align-items: center;
			gap: 6px;
			background: none;
			border: none;
			color: #aaa;
			font-size: 13px;
			cursor: pointer;
			font-family: inherit;
			transition: color 0.15s;
			padding: 0;
		}

		.social-btn:hover { color: #e63946; }
		.social-btn:hover svg { fill: #e63946; }

		.social-btn svg {
			width: 18px;
			height: 18px;
			fill: #aaa;
			transition: fill 0.15s;
		}

		.social-btn.liked svg { fill: #e63946; }
		.social-btn.liked { color: #e63946; }

		/* Divider between social buttons */
		.social-divider {
			width: 1px;
			height: 18px;
			background: #2a2a2a;
		}

		.download-btn-right {
			display: flex;
			align-items: center;
			justify-content: center;
			gap: 10px;
			padding: 16px;
			background: #e63946;
			color: white;
			border-radius: 12px;
			font-size: 16px;
			font-weight: 600;
			text-decoration: none;
			transition: background 0.15s, transform 0.1s;
		}

		.download-btn-right:hover {
			background: #c1121f;
			transform: translateY(-1px);
		}

		.download-btn-right svg {
			width: 18px;
			height: 18px;
			fill: white;
		}

		/* Info table */
		.info-table {
			border-top: 1px solid #2a2a2a;
			padding: 16px 20px 20px;
		}

		.info-row {
			display: flex;
			justify-content: space-between;
			align-items: center;
			padding: 8px 0;
			font-size: 13px;
			border-bottom: 1px solid #1f1f1f;
		}

		.info-row:last-child { border-bottom: none; }
		.info-row .label { color: #666; }
		.info-row .value { color: #ddd; font-weight: 500; }

		/* ── RIGHT PANEL ── */
		.right-panel {
			width: 420px;
			display: flex;
			flex-direction: column;
			gap: 16px;
		}

		.panel-box {
			background: #161616;
			border-radius: 16px;
			border: 1px solid #2a2a2a;
			padding: 24px;
		}

		.panel-box h3 {
			margin: 0 0 18px;
			font-size: 17px;
			font-weight: 700;
			color: #fff;
			letter-spacing: 0.02em;
		}

		/* Description box */
		.description-text {
			font-size: 14px;
			line-height: 1.7;
			color: #bbb;
			margin: 0 0 16px;
		}

		.meta-line {
			font-size: 13px;
			color: #888;
			margin-bottom: 12px;
		}

		.meta-line b { color: #ccc; }

		.tag-list {
			display: flex;
			flex-wrap: wrap;
			gap: 6px;
			margin-top: 4px;
		}

		.tag-badge {
			border: 1px solid #e63946;
			color: #e63946;
			border-radius: 6px;
			padding: 4px 12px;
			font-size: 12px;
			font-weight: 500;
			letter-spacing: 0.02em;
		}

		/* Rating box */
		.rating-box {
			display: flex;
			align-items: center;
			gap: 10px;
		}

		.stars {
			display: flex;
			gap: 4px;
		}

		.stars svg {
			width: 26px;
			height: 26px;
		}

		.star-filled { fill: #f5a623; stroke: #f5a623; stroke-width: 1.5; }
		.star-empty { fill: none; stroke: #f5a623; stroke-width: 1.5; }

		.rating-score {
			font-size: 22px;
			font-weight: 700;
			color: #f5a623;
		}

		.rating-max {
			font-size: 14px;
			color: #666;
		}

		/* ── INTERACTIVE RATING ── */
		.rate-section {
			margin-top: 16px;
			padding-top: 16px;
			border-top: 1px solid #2a2a2a;
		}

		.rate-label {
			font-size: 13px;
			color: #888;
			margin-bottom: 10px;
		}

		.rate-stars {
			display: flex;
			gap: 6px;
		}

		.rate-star {
			width: 28px;
			height: 28px;
			cursor: pointer;
			flex-shrink: 0;
			transition: transform 0.1s;
		}

		.rate-star:hover {
			transform: scale(1.2);
		}

		.rate-star polygon {
			fill: none;
			stroke: #f5a623;
			stroke-width: 1.5;
			transition: fill 0.1s;
		}

		.rate-star.active polygon,
		.rate-star.hovered polygon {
			fill: #f5a623;
		}

		.rate-feedback {
			font-size: 12px;
			color: #666;
			margin-top: 8px;
			min-height: 16px;
		}

		.rate-delete-btn {
			display: none;
			align-items: center;
			gap: 6px;
			background: transparent;
			border: 1px solid #3a3a3a;
			color: #888;
			font-size: 12px;
			cursor: pointer;
			padding: 5px 10px;
			border-radius: 6px;
			font-family: inherit;
			transition: all 0.15s;
		}

		.rate-delete-btn svg {
			width: 14px;
			height: 14px;
			flex-shrink: 0;
		}

		.rate-delete-btn:hover {
			color: #e63946;
			border-color: #e63946;
			background: rgba(230, 57, 70, 0.08);
		}

		.rate-delete-btn.visible { display: flex; }

		.rate-delete-success {
			display: none;
			font-size: 12px;
			color: #4caf50;
		}

		.rate-delete-success.visible { display: inline; }

		.rate-own-notice {
			font-size: 13px;
			color: #555;
			font-style: italic;
			margin-top: 16px;
			padding-top: 16px;
			border-top: 1px solid #2a2a2a;
		}
	</style>

	<div class="content-outer">
	<div class="page-wrapper">

		<!-- LEFT PANEL -->
		<div class="left-panel">

			<div class="cover-wrapper">
				{% if content.imageFile %}
					<img src="{{ asset(content.imageFile) }}" alt="{{ content.title }}"/>
				{% else %}
					<div class="cover-placeholder">&#127925;</div>
				{% endif %}
				{% if 'soundkit' not in content.type.name|lower and 'sound kit' not in content.type.name|lower %}
				<div class="play-overlay">
					<button class="play-circle" id="play-btn">▶</button>
				</div>
				{% endif %}
			</div>

			<div class="track-meta">
				<h2>{{ content.title }}</h2>
				{% if content.fkUser %}
					<a href="{{ path('app_userprofile', { username: content.fkUser.username }) }}" class="artist">
						{{ content.fkUser.username }}
					</a>
				{% else %}
					<span class="artist">Unknown</span>
				{% endif %}
			</div>

			{% if 'soundkit' not in content.type.name|lower and 'sound kit' not in content.type.name|lower %}
			<div class="waveform-wrap">
				<div id="waveform"></div>
			</div>
			{% endif %}

			<div class="social-row">
				<!-- Likes -->
				<button class="social-btn {{ isFavorited ? 'liked' : '' }}" id="fav-btn" data-content-id="{{ content.id }}">
					<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" id="fav-icon">
						{% if isFavorited %}
							<path fill="#e63946" d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
						{% else %}
							<path fill="none" stroke="#aaa" stroke-width="2" d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
						{% endif %}
					</svg>
					<span id="fav-count">{{ favoriteCount }}</span>
				</button>

				<div class="social-divider"></div>

				<!-- Downloads -->
				<span class="social-btn">
					<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
						<path d="M12 16l-5-5h3.5V4h3v7H17l-5 5zm-7 2h14v2H5v-2z"/>
					</svg>
					{{ content.downloadCount }}
				</span>
			</div>

			<div class="info-table">
				<div class="info-row">
					<span class="label">Kategorie</span>
					<span class="value">{{ content.type.name }}</span>
				</div>
			</div>

		</div>

		<!-- RIGHT PANEL -->
		<div class="right-panel">

			<a href="{{ path('content_download', { id: content.id }) }}" class="download-btn-right">
				<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
					<path d="M12 16l-5-5h3.5V4h3v7H17l-5 5zm-7 2h14v2H5v-2z"/>
				</svg>
				Download
			</a>

			<!-- Description + Tags -->
			<div class="panel-box">
				<h3>Informationen</h3>
				<p class="description-text">{{ content.description }}</p>

				<div class="meta-line">
					<b>Tags</b>
				</div>
				<div class="tag-list">
					{% for tag in tags %}
						<span class="tag-badge">{{ tag.fkTag.name }}</span>
					{% endfor %}
				</div>
			</div>

			<!-- Rating -->
			<div class="panel-box">
				<h3>Bewertung</h3>
				<div class="rating-box">
					<div class="stars" id="avg-stars">
						{% for i in 1..5 %}
							{% if averageRating >= i %}
								<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
									<polygon class="star-filled" points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/>
								</svg>
							{% elseif averageRating >= i - 0.5 %}
								<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
									<defs>
										<linearGradient id="half{{ i }}">
											<stop offset="50%" stop-color="#f5a623"/>
											<stop offset="50%" stop-color="transparent"/>
										</linearGradient>
									</defs>
									<polygon fill="url(#half{{ i }})" stroke="#f5a623" stroke-width="1.5" points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/>
								</svg>
							{% else %}
								<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
									<polygon class="star-empty" points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/>
								</svg>
							{% endif %}
						{% endfor %}
					</div>
					<span class="rating-score" id="avg-score">{{ averageRating|number_format(1) }}</span>
					<span class="rating-max">/ 5.0</span>
				</div>

				{% if app.user %}
					{% if app.user.id == content.fkUser.id %}
						<p class="rate-own-notice">Du kannst deinen eigenen Inhalt nicht bewerten.</p>
					{% else %}
						<div class="rate-section">
							<p class="rate-label">Deine Bewertung:</p>
							<div class="rate-stars" id="rate-stars"
								 data-content-id="{{ content.id }}"
								 data-user-rating="{{ userRating ?? 0 }}">
								{% for i in 1..5 %}
									<svg class="rate-star {{ userRating and userRating >= i ? 'active' : '' }}"
										 data-value="{{ i }}"
										 viewBox="0 0 24 24"
										 xmlns="http://www.w3.org/2000/svg">
										<polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/>
									</svg>
								{% endfor %}
							</div>
							<p class="rate-feedback" id="rate-feedback">
								{% if userRating %}Deine Bewertung: {{ userRating }}/5{% endif %}
							</p>
							<div style="display:flex;align-items:center;gap:10px;margin-top:4px;">
								<button class="rate-delete-btn {{ userRating ? 'visible' : '' }}" id="rate-delete-btn">
									<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
										<path d="M6 2h4 M2 4h12 M5 4v9a1 1 0 001 1h4a1 1 0 001-1V4"/>
									</svg>
									Bewertung löschen
								</button>
								<span class="rate-delete-success" id="rate-delete-success">Gelöscht ✓</span>
							</div>
						</div>
					{% endif %}
				{% endif %}
			</div>

		</div>

	</div>

	<!-- COMMENT SECTION -->
	<style>
		.comment-section {
			margin-bottom: 60px;
		}

		.comment-section > h3 {
			font-size: 17px;
			font-weight: 700;
			color: #fff;
			margin-bottom: 20px;
		}

		/* ── forms ── */
		.comment-form {
			background: #161616;
			border: 1px solid #2a2a2a;
			border-radius: 16px;
			padding: 20px;
			margin-bottom: 28px;
		}

		.comment-form textarea {
			width: 100%;
			background: #0e0e0e;
			border: 1px solid #2a2a2a;
			border-radius: 10px;
			color: #fff;
			font-family: 'DM Sans', sans-serif;
			font-size: 14px;
			padding: 12px 14px;
			resize: vertical;
			min-height: 90px;
			outline: none;
			transition: border-color 0.15s;
			box-sizing: border-box;
		}

		.comment-form textarea:focus { border-color: #e63946; }

		.comment-form button {
			margin-top: 10px;
			background: #e63946;
			color: #fff;
			border: none;
			border-radius: 8px;
			padding: 9px 22px;
			font-size: 13px;
			font-weight: 600;
			font-family: 'DM Sans', sans-serif;
			cursor: pointer;
			transition: background 0.15s;
		}

		.comment-form button:hover { background: #c1121f; }

		.comment-form .cancel-reply {
			margin-top: 10px;
			margin-left: 8px;
			background: transparent;
			color: #666;
			border: 1px solid #333;
			border-radius: 8px;
			padding: 9px 16px;
			font-size: 13px;
			font-family: 'DM Sans', sans-serif;
			cursor: pointer;
			transition: color 0.15s, border-color 0.15s;
		}

		.comment-form .cancel-reply:hover { color: #aaa; border-color: #555; }

		.comment-login-hint {
			background: #161616;
			border: 1px solid #2a2a2a;
			border-radius: 16px;
			padding: 18px 20px;
			margin-bottom: 28px;
			font-size: 14px;
			color: #666;
		}

		.comment-login-hint a { color: #e63946; text-decoration: none; }

		/* ── list ── */
		.comment-list { display: flex; flex-direction: column; gap: 14px; }

		.comment-item {
			background: #161616;
			border: 1px solid #2a2a2a;
			border-radius: 12px;
			padding: 16px 18px;
		}

		/* ── header ── */
		.comment-header {
			display: flex;
			align-items: center;
			gap: 10px;
			margin-bottom: 8px;
		}

		.comment-avatar {
			width: 32px;
			height: 32px;
			border-radius: 50%;
			background: #2a2a2a;
			display: flex;
			align-items: center;
			justify-content: center;
			font-size: 13px;
			font-weight: 700;
			color: #e63946;
			flex-shrink: 0;
			overflow: hidden;
		}

		.comment-avatar img { width: 100%; height: 100%; object-fit: cover; }

		.comment-username { font-size: 13px; font-weight: 600; color: #ddd; }

		.comment-date { font-size: 12px; color: #555; margin-left: auto; }

		/* ── body ── */
		.comment-text {
			font-size: 14px;
			color: #bbb;
			line-height: 1.6;
			white-space: pre-wrap;
			word-break: break-word;
			margin-bottom: 10px;
		}

		/* ── actions row ── */
		.comment-actions {
			display: flex;
			align-items: center;
			gap: 14px;
			margin-top: 4px;
		}

		.comment-like-btn, .comment-reply-btn {
			display: flex;
			align-items: center;
			gap: 5px;
			background: none;
			border: none;
			color: #555;
			font-size: 12px;
			font-family: 'DM Sans', sans-serif;
			cursor: pointer;
			padding: 0;
			transition: color 0.15s;
		}

		.comment-like-btn svg, .comment-reply-btn svg {
			width: 14px;
			height: 14px;
			fill: currentColor;
			transition: fill 0.15s;
		}

		.comment-like-btn:hover, .comment-reply-btn:hover { color: #e63946; }

		.comment-like-btn.liked { color: #e63946; }

		.comment-delete-btn {
			display: flex;
			align-items: center;
			gap: 5px;
			background: transparent;
			border: 1px solid #3a3a3a;
			border-radius: 6px;
			color: #888;
			font-size: 12px;
			font-family: 'DM Sans', sans-serif;
			cursor: pointer;
			padding: 4px 10px;
			margin-left: auto;
			transition: color 0.15s, border-color 0.15s, background 0.15s;
		}

		.comment-delete-btn svg {
			width: 13px;
			height: 13px;
			fill: currentColor;
			flex-shrink: 0;
		}

		.comment-delete-btn:hover {
			color: #e63946;
			border-color: #e63946;
			background: rgba(230, 57, 70, 0.08);
		}

		/* ── reply thread ── */
		.reply-thread {
			margin-top: 12px;
			padding-left: 16px;
			border-left: 2px solid #2a2a2a;
			display: flex;
			flex-direction: column;
			gap: 10px;
		}

		.reply-item {
			background: #111;
			border: 1px solid #222;
			border-radius: 10px;
			padding: 12px 14px;
		}

		/* inline reply form */
		.inline-reply-form {
			display: none;
			margin-top: 12px;
			padding: 14px;
			background: #111;
			border: 1px solid #2a2a2a;
			border-radius: 10px;
		}

		.inline-reply-form.open { display: block; }

		.inline-reply-form textarea {
			width: 100%;
			background: #0e0e0e;
			border: 1px solid #2a2a2a;
			border-radius: 8px;
			color: #fff;
			font-family: 'DM Sans', sans-serif;
			font-size: 13px;
			padding: 10px 12px;
			resize: vertical;
			min-height: 70px;
			outline: none;
			transition: border-color 0.15s;
			box-sizing: border-box;
		}

		.inline-reply-form textarea:focus { border-color: #e63946; }

		.comment-empty {
			font-size: 14px;
			color: #555;
			text-align: center;
			padding: 24px 0;
		}
	</style>

	{# ── Macro: render one comment card (used for top-level and replies) ── #}
	{% macro commentCard(comment, likeCounts, likedByUser, contentId, isReply, currentUserId) %}
		{% set cid = comment.id %}
		{% set liked = likedByUser[cid] is defined %}
		{% set likeCount = likeCounts[cid] ?? 0 %}
		<div class="comment-header">
			<div class="comment-avatar">
				{% if comment.fkUser.profilePicture %}
					<img src="{{ asset(comment.fkUser.profilePicture) }}" alt="{{ comment.fkUser.username }}"/>
				{% else %}
					{{ comment.fkUser.username|slice(0,1)|upper }}
				{% endif %}
			</div>
			<span class="comment-username">{{ comment.fkUser.username }}</span>
			<span class="comment-date">{{ comment.createdAt|date('d.m.Y H:i') }}</span>
		</div>
		<p class="comment-text">{{ comment.text }}</p>
		<div class="comment-actions">
			<button class="comment-like-btn {{ liked ? 'liked' : '' }}"
					data-comment-id="{{ cid }}">
				<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
					<path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
				</svg>
				<span class="like-count">{{ likeCount }}</span>
			</button>
			{% if not isReply %}
				<button class="comment-reply-btn" data-target="reply-form-{{ cid }}">
					<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
						<path d="M10 9V5l-7 7 7 7v-4.1c5 0 8.5 1.6 11 5.1-1-5-4-10-11-11z"/>
					</svg>
					Antworten
				</button>
			{% endif %}
			{% if currentUserId == comment.fkUser.id %}
				<form method="POST" action="/comment/{{ cid }}/delete" style="margin-left:auto;">
					<button type="submit" class="comment-delete-btn">
						<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
							<path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/>
						</svg>
						Löschen
					</button>
				</form>
			{% endif %}
		</div>
	{% endmacro %}

	{% import _self as macros %}
	{% set currentUserId = app.user ? app.user.id : null %}

	<div class="comment-section">
		<h3>Kommentare ({{ comments|length }})</h3>

		{% if app.user %}
			<div class="comment-form">
				<form method="POST" action="{{ path('content_comment', { id: content.id }) }}">
					<textarea name="text" placeholder="Schreib einen Kommentar…" maxlength="2000" required></textarea>
					<button type="submit">Kommentar abschicken</button>
				</form>
			</div>
		{% else %}
			<div class="comment-login-hint">
				<a href="{{ path('app_login') }}">Melde dich an</a>, um einen Kommentar zu hinterlassen.
			</div>
		{% endif %}

		<div class="comment-list">
			{% if comments|length > 0 %}
				{% for comment in comments %}
					<div class="comment-item">
						{{ macros.commentCard(comment, likeCounts, likedByUser, content.id, false, currentUserId) }}

						{# ── inline reply form ── #}
						{% if app.user %}
							<div class="inline-reply-form" id="reply-form-{{ comment.id }}">
								<form method="POST" action="{{ path('content_comment', { id: content.id }) }}">
									<input type="hidden" name="parent_id" value="{{ comment.id }}"/>
									<textarea name="text" placeholder="Antwort schreiben…" maxlength="1000" required></textarea>
									<button type="submit">Antworten</button>
									<button type="button" class="cancel-reply" data-target="reply-form-{{ comment.id }}">Abbrechen</button>
								</form>
							</div>
						{% endif %}

						{# ── replies ── #}
						<div class="reply-thread" id="replies-{{ comment.id }}"{% if comment.replies|length == 0 %} style="display:none"{% endif %}>
							{% for reply in comment.replies %}
								<div class="reply-item">
									{{ macros.commentCard(reply, likeCounts, likedByUser, content.id, true, currentUserId) }}
								</div>
							{% endfor %}
						</div>
					</div>
				{% endfor %}
			{% else %}
				<p class="comment-empty">Noch keine Kommentare. Sei der Erste!</p>
			{% endif %}
		</div>
	</div>

	</div>{# end .content-outer #}

	<script>
		const CONTENT_ID      = {{ content.id }};
		const CURRENT_USER_ID = {{ app.user ? app.user.id : 'null' }};
	</script>

	<script>
		(function () {
			function escHtml(str) {
				return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
			}

			function buildAvatar(pic, username) {
				if (pic) return '<img src="/' + escHtml(pic) + '" alt="' + escHtml(username) + '"/>';
				return escHtml(username.charAt(0).toUpperCase());
			}

			function buildCommentCard(data, isReply) {
				const isOwn  = CURRENT_USER_ID && data.userId == CURRENT_USER_ID;
				const replyBtn = !isReply
					? `<button class="comment-reply-btn" data-target="reply-form-${data.id}">
						<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M10 9V5l-7 7 7 7v-4.1c5 0 8.5 1.6 11 5.1-1-5-4-10-11-11z"/></svg>
						Antworten
					</button>` : '';
				const deleteBtn = isOwn
					? `<form method="POST" action="/comment/${data.id}/delete" style="margin-left:auto;">
						<button type="submit" class="comment-delete-btn">
							<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/></svg>
							Löschen
						</button>
					</form>` : '';
				const replyForm = (!isReply && CURRENT_USER_ID)
					? `<div class="inline-reply-form" id="reply-form-${data.id}">
						<form>
							<input type="hidden" name="parent_id" value="${data.id}"/>
							<textarea name="text" placeholder="Antwort schreiben…" maxlength="1000" required></textarea>
							<button type="submit">Antworten</button>
							<button type="button" class="cancel-reply" data-target="reply-form-${data.id}">Abbrechen</button>
						</form>
					</div>
					<div class="reply-thread" id="replies-${data.id}" style="display:none"></div>` : '';

				const wrap = document.createElement('div');
				wrap.className = isReply ? 'reply-item' : 'comment-item';
				wrap.innerHTML = `
					<div class="comment-header">
						<div class="comment-avatar">${buildAvatar(data.profilePicture, data.username)}</div>
						<span class="comment-username">${escHtml(data.username)}</span>
						<span class="comment-date">${escHtml(data.createdAt)}</span>
					</div>
					<p class="comment-text"></p>
					<div class="comment-actions">
						<button class="comment-like-btn" data-comment-id="${data.id}">
							<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
							<span class="like-count">0</span>
						</button>
						${replyBtn}
						${deleteBtn}
					</div>
					${replyForm}`;
				wrap.querySelector('.comment-text').textContent = data.text;
				return wrap;
			}

			// ── Enter to submit (Shift+Enter = new line) ──
			document.addEventListener('keydown', function (e) {
				if (e.key !== 'Enter' || e.shiftKey) return;
				var ta = e.target;
				if (!ta.matches('.comment-form textarea, .inline-reply-form textarea')) return;
				e.preventDefault();
				ta.closest('form').requestSubmit();
			});

			// ── AJAX comment submit ──
			document.addEventListener('submit', async function (e) {
				const form = e.target;
				if (!form.closest('.comment-form, .inline-reply-form')) return;
				e.preventDefault();

				const ta       = form.querySelector('textarea');
				const text     = ta.value.trim();
				if (!text) return;

				const parentInput = form.querySelector('[name="parent_id"]');
				const parentId    = parentInput ? parseInt(parentInput.value) : null;

				const body = new URLSearchParams({ text });
				if (parentId) body.append('parent_id', parentId);

				const res = await fetch('/content/' + CONTENT_ID + '/comment', {
					method: 'POST',
					headers: {
						'Content-Type': 'application/x-www-form-urlencoded',
						'X-Requested-With': 'XMLHttpRequest',
					},
					body,
				});
				if (!res.ok) return;
				const data = await res.json();

				const card = buildCommentCard(data, !!parentId);
				ta.value = '';

				if (parentId) {
					// append reply under parent
					const thread = document.getElementById('replies-' + parentId);
					if (thread) {
						thread.appendChild(card);
						thread.style.display = '';
					}
					// close reply form
					const replyForm = document.getElementById('reply-form-' + parentId);
					if (replyForm) replyForm.classList.remove('open');
				} else {
					// prepend top-level comment
					const list  = document.querySelector('.comment-list');
					const empty = list.querySelector('.comment-empty');
					if (empty) empty.remove();
					list.prepend(card);
					// update counter
					const h3 = document.querySelector('.comment-section > h3');
					if (h3) h3.textContent = 'Kommentare (' + list.querySelectorAll(':scope > .comment-item').length + ')';
				}
			});

			// ── Event delegation: comment delete ──
			document.addEventListener('submit', async function (e) {
				const form = e.target;
				if (!form.closest('.comment-actions')) return;
				if (!form.action.includes('/delete')) return;
				e.preventDefault();

				if (!confirm('Kommentar wirklich löschen?')) return;

				const card = form.closest('.comment-item, .reply-item');
				const res  = await fetch(form.action, {
					method: 'POST',
					headers: { 'X-Requested-With': 'XMLHttpRequest' },
				});
				if (!res.ok) return;

				// update counter before removing
				if (card && card.classList.contains('comment-item')) {
					const h3   = document.querySelector('.comment-section > h3');
					const list = document.querySelector('.comment-list');
					if (h3 && list) {
						const count = list.querySelectorAll(':scope > .comment-item').length - 1;
						h3.textContent = 'Kommentare (' + count + ')';
					}
				}
				if (card) card.remove();
			});

			// ── Event delegation: reply toggle ──
			document.addEventListener('click', function (e) {
				const replyBtn = e.target.closest('.comment-reply-btn');
				if (replyBtn) {
					const form = document.getElementById(replyBtn.dataset.target);
					if (form) form.classList.toggle('open');
					return;
				}
				const cancelBtn = e.target.closest('.cancel-reply');
				if (cancelBtn) {
					const form = document.getElementById(cancelBtn.dataset.target);
					if (form) form.classList.remove('open');
				}
			});

			// ── Event delegation: comment like ──
			document.addEventListener('click', async function (e) {
				const btn = e.target.closest('.comment-like-btn');
				if (!btn) return;
				const commentId = btn.dataset.commentId;
				const res = await fetch('/comment/' + commentId + '/like', {
					method: 'POST',
					headers: { 'X-Requested-With': 'XMLHttpRequest' },
				});
				if (res.status === 401 || !res.ok) return;
				const data = await res.json();
				btn.classList.toggle('liked', data.liked);
				btn.querySelector('.like-count').textContent = data.count;
			});
		})();
	</script>

	<script>
		(function () {
			const btn   = document.getElementById('fav-btn');
			const count = document.getElementById('fav-count');
			const icon  = document.getElementById('fav-icon');
			if (!btn) return;

			const filledPath = 'M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z';

			btn.addEventListener('click', async function () {
				const id  = btn.dataset.contentId;
				const res = await fetch('/favoriten/toggle/' + id, {
					method: 'POST',
					headers: { 'X-Requested-With': 'XMLHttpRequest' },
				});
				if (!res.ok) return;
				const data = await res.json();

				count.textContent = data.count;
				btn.classList.toggle('liked', data.favorited);

				const path = icon.querySelector('path');
				if (data.favorited) {
					path.setAttribute('fill', '#e63946');
					path.removeAttribute('stroke');
					path.removeAttribute('stroke-width');
				} else {
					path.setAttribute('fill', 'none');
					path.setAttribute('stroke', '#aaa');
					path.setAttribute('stroke-width', '2');
				}
			});
		})();
	</script>

	<script>
		(function () {
			const container = document.getElementById('rate-stars');
			if (!container) return;

			const stars     = Array.from(container.querySelectorAll('.rate-star'));
			const feedback  = document.getElementById('rate-feedback');
			const avgScore  = document.getElementById('avg-score');
			const avgStars  = document.getElementById('avg-stars');
			const contentId = container.dataset.contentId;
			let current     = parseInt(container.dataset.userRating) || 0;

			const POINTS = '12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26';

			function setHover(upTo) {
				stars.forEach((s, i) => s.classList.toggle('hovered', i < upTo));
			}

			function setActive(upTo) {
				stars.forEach((s, i) => s.classList.toggle('active', i < upTo));
			}

			function renderAvg(avg) {
				avgScore.textContent = avg.toFixed(1);
				avgStars.innerHTML = '';
				for (let i = 1; i <= 5; i++) {
					const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
					svg.setAttribute('viewBox', '0 0 24 24');
					svg.setAttribute('xmlns', 'http://www.w3.org/2000/svg');
					svg.style.cssText = 'width:26px;height:26px';
					const poly = document.createElementNS('http://www.w3.org/2000/svg', 'polygon');
					poly.setAttribute('points', POINTS);

					if (avg >= i) {
						poly.setAttribute('fill', '#f5a623');
						poly.setAttribute('stroke', '#f5a623');
						poly.setAttribute('stroke-width', '1.5');
						svg.appendChild(poly);
					} else if (avg >= i - 0.5) {
						const gradId = 'half-js-' + i;
						const defs   = document.createElementNS('http://www.w3.org/2000/svg', 'defs');
						const grad   = document.createElementNS('http://www.w3.org/2000/svg', 'linearGradient');
						grad.setAttribute('id', gradId);
						const s1 = document.createElementNS('http://www.w3.org/2000/svg', 'stop');
						s1.setAttribute('offset', '50%');
						s1.setAttribute('stop-color', '#f5a623');
						const s2 = document.createElementNS('http://www.w3.org/2000/svg', 'stop');
						s2.setAttribute('offset', '50%');
						s2.setAttribute('stop-color', 'transparent');
						grad.appendChild(s1);
						grad.appendChild(s2);
						defs.appendChild(grad);
						svg.appendChild(defs);
						poly.setAttribute('fill', 'url(#' + gradId + ')');
						poly.setAttribute('stroke', '#f5a623');
						poly.setAttribute('stroke-width', '1.5');
						svg.appendChild(poly);
					} else {
						poly.setAttribute('fill', 'none');
						poly.setAttribute('stroke', '#f5a623');
						poly.setAttribute('stroke-width', '1.5');
						svg.appendChild(poly);
					}

					avgStars.appendChild(svg);
				}
			}

			container.addEventListener('mouseover', e => {
				const s = e.target.closest('.rate-star');
				if (s) setHover(parseInt(s.dataset.value));
			});

			container.addEventListener('mouseleave', () => setHover(0));

			container.addEventListener('click', async e => {
				const s = e.target.closest('.rate-star');
				if (!s) return;
				const value = parseInt(s.dataset.value);

				const res = await fetch('/content/' + contentId + '/rate', {
					method: 'POST',
					headers: {
						'Content-Type': 'application/x-www-form-urlencoded',
						'X-Requested-With': 'XMLHttpRequest',
					},
					body: 'value=' + value,
				});

				if (res.status === 401) { feedback.textContent = 'Du musst eingeloggt sein, um zu bewerten.'; return; }
				if (!res.ok) return;

				const data = await res.json();
				current = value;
				setActive(current);
				renderAvg(data.average);
				feedback.textContent = 'Deine Bewertung: ' + value + '/5';
				deleteBtn.classList.add('visible');
			});

			const deleteBtn    = document.getElementById('rate-delete-btn');
			const deleteSuccess = document.getElementById('rate-delete-success');
			if (deleteBtn) {
				deleteBtn.addEventListener('click', async () => {
					const res = await fetch('/content/' + contentId + '/rate', {
						method: 'DELETE',
						headers: { 'X-Requested-With': 'XMLHttpRequest' },
					});
					if (!res.ok) return;

					const data = await res.json();
					current = 0;
					setActive(0);
					setHover(0);
					renderAvg(data.average);
					if (feedback) feedback.textContent = '';

					deleteBtn.classList.remove('visible');
					if (deleteSuccess) {
						deleteSuccess.classList.add('visible');
						setTimeout(() => deleteSuccess.classList.remove('visible'), 2000);
					}
				});
			}
		})();
	</script>

	{% if 'soundkit' not in content.type.name|lower and 'sound kit' not in content.type.name|lower %}
	<script type="module">
		import WaveSurfer from 'https://unpkg.com/wavesurfer.js@7/dist/wavesurfer.esm.js';

		const btn = document.getElementById('play-btn');

		const ws = WaveSurfer.create({
			container: '#waveform',
			url: '{{ asset('uploads/' ~ content.filePath) }}',
			waveColor: '#3a3a3a',
			progressColor: '#e63946',
			height: 40,
			barWidth: 2,
			barGap: 2,
			barRadius: 2,
			cursorColor: '#e63946',
			cursorWidth: 2,
			interact: true,
		});

		btn.addEventListener('click', () => ws.playPause());

		ws.on('play',   () => { btn.textContent = '⏸'; });
		ws.on('pause',  () => { btn.textContent = '▶'; });
		ws.on('finish', () => { btn.textContent = '▶'; });
	</script>
	{% endif %}

{% endblock %}
