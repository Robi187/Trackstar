{% extends 'user_management/index.html.twig' %}

{% block title %}Meine Favoriten – TrackStar{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
  .content-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 20px; }
  .card { background: #1a1a1a; border-radius: 12px; overflow: hidden; cursor: pointer; transition: transform 0.2s, box-shadow 0.2s; border: 1px solid #2a2a2a; }
  .card:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(0,0,0,0.4); }
  .card-cover { width: 100%; aspect-ratio: 1 / 1; object-fit: cover; display: block; }
  .card-cover-placeholder { width: 100%; aspect-ratio: 1 / 1; background: #2a2a2a; display: flex; align-items: center; justify-content: center; font-size: 36px; }
  .card-body { padding: 10px 12px 12px; }
  .card-title { font-size: 14px; font-weight: 600; color: #fff; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-bottom: 4px; }
  .card-user { font-size: 12px; color: #888; margin-bottom: 8px; }
  .card-footer { display: flex; flex-wrap: wrap; gap: 4px; }
  .card-tag { background: #2a2a2a; color: #aaa; font-size: 11px; padding: 2px 8px; border-radius: 20px; }
  .empty-state { color: #666; font-size: 14px; }
</style>
{% endblock %}

{% block ku_content %}
  <h1 class="ku-title">Meine Favoriten</h1>
  <p class="ku-subtitle">Hier werden Inhalte angezeigt die du Favorisiert hast</p>

  {% if contents|length > 0 %}
    <div class="content-grid">
      {% for item in contents %}
        <div class="card" onclick="window.location.href='/content/{{ item.id }}'">

          {% if item.imageFile %}
            <img
              class="card-cover"
              src="{{ asset(item.imageFile) }}"
              alt="{{ item.title }}"
              loading="lazy"
            />
          {% else %}
            <div class="card-cover-placeholder">&#127925;</div>
          {% endif %}

          <div class="card-body">
            <div class="card-title" title="{{ item.title }}">{{ item.title }}</div>
            {% if item.fkUser %}
              <div class="card-user">{{ item.fkUser.username }}</div>
            {% endif %}
            <div class="card-footer">
              {% if tagsByContent[item.id] is defined %}
                {% for tag in tagsByContent[item.id] %}
                  <span class="card-tag">{{ tag.fkTag.name }}</span>
                {% endfor %}
              {% endif %}
            </div>
          </div>

        </div>
      {% endfor %}
    </div>
  {% else %}
    <div class="empty-state">
      Du hast noch keine Inhalte favorisiert.
    </div>
  {% endif %}
{% endblock %}
