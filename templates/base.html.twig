<!DOCTYPE html>
<html>
	<head>
		<meta charset="UTF-8">
		<title>
			{% block title %}Trackstar{% endblock %}
		</title>
		<link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
		{% block stylesheets %}
			<link rel="stylesheet" href="{{ asset('css/app.css') }}">
			<style>
				* {
					margin: 0;
					padding: 0;
					box-sizing: border-box;
				}

				@import url('https://fonts.adobe.com/fonts/futura-pt');
				@import url('https://fonts.adobe.com/fonts/sofia-pro');
				@import url('https://fonts.adobe.com/fonts/acumin-pro');
				@import url("https://use.typekit.net/tqp0iic.css");

				*,
				*::before,
				*::after {
					box-sizing: border-box;
					margin: 0;
					padding: 0;
				}

				:root {
					--bg: #000000;
					--surface: #111113;
					--border: #2a2a2d;
					--orange: #ff5a00;
					--orange-h: #ff7020;
					--red: #e02434;
					--text: #ffffff;
					--muted: #8a8a8e;
					--input-bg: #3a3c41;

					--font-heading: 'futura-pt', 'Outfit', sans-serif;
					--font-subheading: 'sofia-pro', 'Outfit', sans-serif;
					--font-body: 'acumin-pro', 'Outfit', sans-serif;
				}

				h1, h2, h3, h4, h5, h6 {
					font-family: var(--font-heading);
					font-weight: 600;
					font-style: italic;
				}

				body {
					background-color: #1a1a1a;
					color: #ffffff;
					font-family: 'Arial', sans-serif;
					min-height: 100vh;
				}

				/* ── NAVBAR ── */
				.navbar {
					display: flex;
					align-items: center;
					justify-content: space-between;
					padding: 14px 32px;
					background-color: #111111;
					border-bottom: 1px solid #2a2a2a;
					position: relative;
					z-index: 100;
				}

				.navbar-logo {
					font-size: 1.4rem;
					font-weight: 800;
					letter-spacing: -0.5px;
					text-decoration: none;
					color: #ffffff;
				}

				.navbar-logo span { color: var(--orange); }

				.navbar-search {
					flex: 1;
					max-width: 360px;
					margin: 0 40px;
					position: relative;
				}

				.navbar-search input {
					width: 100%;
					background-color: #2a2a2a;
					border: 1px solid #3a3a3a;
					border-radius: 6px;
					color: #ccc;
					font-size: 0.85rem;
					padding: 8px 14px 8px 36px;
					outline: none;
					transition: border-color 0.2s;
				}

				.navbar-search input::placeholder { color: #666; }
				.navbar-search input:focus { border-color: var(--orange); }

				.navbar-search .search-icon {
					position: absolute;
					left: 11px;
					top: 50%;
					transform: translateY(-50%);
					color: #666;
					font-size: 0.85rem;
				}

				.navbar-right {
					display: flex;
					align-items: center;
					gap: 16px;
				}

				.navbar-shop {
					color: #ffffff;
					text-decoration: none;
					font-size: 0.9rem;
					font-weight: 500;
					transition: color 0.2s;
				}

				.navbar-shop:hover { color: var(--orange); }

				.navbar-avatar {
					width: 34px;
					height: 34px;
					background-color: #2a2a2a;
					border: 1px solid #3a3a3a;
					border-radius: 50%;
					display: flex;
					align-items: center;
					justify-content: center;
					cursor: pointer;
					color: #aaa;
					font-size: 1rem;
					transition: border-color 0.2s;
				}

				.navbar-avatar:hover {
					border-color: var(--orange);
					color: var(--orange);
				}

				/* ── MENU BUTTON ── */
				.navbar-menu-btn {
					width: 34px;
					height: 34px;
					background: none;
					border: none;
					cursor: pointer;
					display: flex;
					flex-direction: column;
					align-items: center;
					justify-content: center;
					gap: 5px;
					padding: 4px;
					border-radius: 6px;
					transition: background-color 0.2s;
				}

				.navbar-menu-btn:hover {
					background-color: #2a2a2a;
				}

				.navbar-menu-btn span {
					display: block;
					width: 20px;
					height: 2px;
					background-color: #cccccc;
					border-radius: 2px;
					transition: all 0.3s ease;
					transform-origin: center;
				}

				.navbar-menu-btn.is-open span:nth-child(1) {
					transform: translateY(7px) rotate(45deg);
				}

				.navbar-menu-btn.is-open span:nth-child(2) {
					opacity: 0;
					transform: scaleX(0);
				}

				.navbar-menu-btn.is-open span:nth-child(3) {
					transform: translateY(-7px) rotate(-45deg);
				}

				/* ── SLIDE-IN OVERLAY ── */
				.menu-overlay {
					position: fixed;
					inset: 0;
					background-color: rgba(0, 0, 0, 0.55);
					z-index: 200;
					opacity: 0;
					pointer-events: none;
					transition: opacity 0.3s ease;
				}

				.menu-overlay.is-open {
					opacity: 1;
					pointer-events: all;
				}

				/* ── SLIDE-IN SIDEBAR ── */
				.menu-sidebar {
					position: fixed;
					top: 0;
					right: 0;
					width: 300px;
					height: 100vh;
					background-color: #111111;
					border-left: 1px solid #2a2a2a;
					z-index: 300;
					transform: translateX(100%);
					transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
					display: flex;
					flex-direction: column;
				}

				.menu-sidebar.is-open {
					transform: translateX(0);
				}

				/* ── SIDEBAR HEADER ── */
				.sidebar-header {
					display: flex;
					align-items: center;
					justify-content: space-between;
					padding: 18px 24px;
					border-bottom: 1px solid #2a2a2a;
				}

				.sidebar-header-title {
					font-size: 0.95rem;
					font-weight: 700;
					color: #ffffff;
					letter-spacing: 0.02em;
					text-transform: uppercase;
					font-family: var(--font-heading);
					font-style: italic;
				}

				.sidebar-close-btn {
					width: 30px;
					height: 30px;
					background: none;
					border: 1px solid #2a2a2a;
					border-radius: 6px;
					cursor: pointer;
					display: flex;
					align-items: center;
					justify-content: center;
					color: #888;
					font-size: 1.1rem;
					line-height: 1;
					transition: all 0.2s;
				}

				.sidebar-close-btn:hover {
					border-color: var(--orange);
					color: var(--orange);
				}

				/* ── SIDEBAR USER INFO ── */
				.sidebar-user {
					display: flex;
					align-items: center;
					gap: 14px;
					padding: 20px 24px;
					border-bottom: 1px solid #2a2a2a;
				}

				.sidebar-user-avatar {
					width: 46px;
					height: 46px;
					background: linear-gradient(135deg, var(--orange), #cc3a00);
					border-radius: 50%;
					display: flex;
					align-items: center;
					justify-content: center;
					font-size: 1.2rem;
					flex-shrink: 0;
				}

				.sidebar-user-name {
					font-size: 0.95rem;
					font-weight: 600;
					color: #ffffff;
					margin-bottom: 2px;
				}

				.sidebar-user-handle {
					font-size: 0.78rem;
					color: #666;
				}

				/* ── SIDEBAR NAV ── */
				.sidebar-nav {
					flex: 1;
					padding: 12px 0;
					overflow-y: auto;
				}

				.sidebar-nav-item {
					display: flex;
					align-items: center;
					gap: 14px;
					padding: 14px 24px;
					color: #cccccc;
					text-decoration: none;
					font-size: 0.9rem;
					font-weight: 500;
					transition: all 0.18s;
					cursor: pointer;
					border: none;
					background: none;
					width: 100%;
					text-align: left;
				}

				.sidebar-nav-item:hover {
					background-color: #1a1a1a;
					color: #ffffff;
				}

				.sidebar-nav-item:hover .sidebar-nav-icon {
					color: var(--orange);
				}

				.sidebar-nav-icon {
					width: 20px;
					height: 20px;
					display: flex;
					align-items: center;
					justify-content: center;
					color: #555;
					flex-shrink: 0;
					transition: color 0.18s;
				}

				.sidebar-nav-icon svg {
					width: 18px;
					height: 18px;
					fill: currentColor;
				}

				/* ── SIDEBAR DIVIDER ── */
				.sidebar-divider {
					height: 1px;
					background-color: #1e1e1e;
					margin: 8px 24px;
				}

				/* ── SIDEBAR FOOTER ── */
				.sidebar-footer {
					padding: 16px 24px;
					border-top: 1px solid #2a2a2a;
				}

				.sidebar-footer-link {
					display: flex;
					align-items: center;
					gap: 10px;
					font-size: 0.78rem;
					color: #555;
					text-decoration: none;
					transition: color 0.18s;
					margin-bottom: 8px;
				}

				.sidebar-footer-link:last-child {
					margin-bottom: 0;
				}

				.sidebar-footer-link:hover {
					color: #888;
				}

				/* ── LOGOUT ITEM ── */
				.sidebar-nav-item.logout {
					color: #cc3333;
				}

				.sidebar-nav-item.logout .sidebar-nav-icon {
					color: #cc3333;
				}

				.sidebar-nav-item.logout:hover {
					background-color: rgba(224, 36, 52, 0.08);
					color: var(--red);
				}

				.sidebar-nav-item.logout:hover .sidebar-nav-icon {
					color: var(--red);
				}

				/* ── SUBNAV ── */
				.subnav {
					display: flex;
					align-items: center;
					justify-content: center;
					gap: 48px;
					padding: 14px 32px;
					background-color: #111111;
					border-bottom: 1px solid #2a2a2a;
				}

				.subnav a {
					color: #cccccc;
					text-decoration: none;
					font-size: 0.9rem;
					font-weight: 500;
					display: flex;
					align-items: center;
					gap: 7px;
					transition: color 0.2s;
				}

				.subnav a:hover { color: var(--orange-h); }
				.subnav a.active { color: #ffffff; }

				.subnav a svg {
					width: 15px;
					height: 15px;
					fill: currentColor;
				}

				/* ── MAIN ── */
				.main {
					padding: 48px 32px 64px;
					max-width: 1200px;
					margin: 0 auto;
				}

				.section-title {
					font-size: 1.75rem;
					font-weight: 700;
					text-align: center;
					margin-bottom: 40px;
					color: #ffffff;
				}

				/* ── GRID ── */
				.content-grid {
					display: grid;
					grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
					gap: 28px;
				}

				/* ── CARD ── */
				.card {
					background-color: #111111;
					border-radius: 8px;
					overflow: hidden;
					cursor: pointer;
					transition: transform 0.2s, box-shadow 0.2s;
				}

				.card:hover {
					transform: translateY(-4px);
					box-shadow: 0 8px 24px rgba(0, 0, 0, 0.5);
				}

				.card-cover {
					width: 100%;
					aspect-ratio: 1 / 1;
					object-fit: cover;
					display: block;
					background-color: #2a2a2a;
				}

				.card-cover-placeholder {
					width: 100%;
					aspect-ratio: 1 / 1;
					background: linear-gradient(135deg, #2a2a2a 0%, #1a1a1a 100%);
					display: flex;
					align-items: center;
					justify-content: center;
					color: #444;
					font-size: 2.5rem;
				}

				.card-body { padding: 12px 12px 14px; }

				.card-title {
					text-align: center;
					font-size: 0.85rem;
					font-weight: 600;
					color: #ffffff;
					margin-bottom: 3px;
					line-height: 1.35;
					white-space: nowrap;
					overflow: hidden;
					text-overflow: ellipsis;
				}

				.card-user {
					text-align: center;
					font-size: 0.78rem;
					color: #888888;
					margin-bottom: 10px;
				}

				.card-footer {
					display: flex;
					justify-content: center;
					align-items: center;
					gap: 6px;
				}

				.card-price {
					background-color: #2a2a2a;
					border-radius: 4px;
					padding: 4px 10px;
					font-size: 0.8rem;
					font-weight: 600;
					color: #ffffff;
					display: inline-flex;
					align-items: center;
					gap: 5px;
				}

				.card-price svg {
					width: 12px;
					height: 12px;
					fill: currentColor;
					color: #aaa;
				}

				.card-tag {
					align-items: center;
					text-align: center;
					font-size: 0.72rem;
					color: #666;
					background-color: #222;
					border-radius: 3px;
					padding: 3px 7px;
				}

				.empty-state {
					text-align: center;
					color: #555;
					padding: 80px 0;
					font-size: 1rem;
				}

				.tag-badge {
					display: inline-block;
					border: 1px solid var(--orange);
					color: var(--orange);
					border-radius: 5px;
					padding: 3px 10px;
					font-size: 0.8rem;
					margin: 2px;
				}

				.navbar-upload-btn {
					width: 34px;
					height: 34px;
					background-color: #ff5a00;
					border-radius: 50%;
					display: flex;
					align-items: center;
					justify-content: center;
					color: #fff;
					font-size: 1.3rem;
					font-weight: 300;
					text-decoration: none;
					line-height: 1;
					transition: background 0.2s, transform 0.1s;
				}

				.navbar-upload-btn:hover {
					background-color: #e85000;
					transform: scale(1.08);
				}
			</style>
		{% endblock %}

		{% block javascripts %}{% endblock %}
	</head>
	<body>

		{# ── NAVBAR ── #}
		{% block navbar %}
		<nav class="navbar">
			<a href="/home" class="navbar-logo">Track<span>Star</span></a>

			<div class="navbar-search">
				<span class="search-icon">&#128269;</span>
				<input type="text" placeholder="Suche"/>
			</div>

			

			<div class="navbar-right">
				<a href="/upload" class="navbar-upload-btn">+</a>
				<a href="/shop" class="navbar-shop">Deine Inhalte</a>
				<div class="navbar-avatar">&#128100;</div>
			</div>
		</nav>

		{# ── SUBNAV ── #}
		<nav class="subnav">
			<a href="/entdecke-tracks">
				<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
					<path d="M12 3v10.55A4 4 0 1 0 14 17V7h4V3h-6z"/>
				</svg>
				Tracks
			</a>
			<a href="/entdecke-sound-kits">
				<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
					<path d="M20 2H4a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2zm-9 13H9V9h2v6zm4 0h-2V9h2v6z"/>
				</svg>
				SoundKits
			</a>
			<a href="/entdecke-loop-und-samples">
				<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
					<path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3A4.5 4.5 0 0 0 14 7.97v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/>
				</svg>
				Loops&amp;Samples
			</a>
			<a href="/entdecke-beats">
				<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
					<path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z"/>
				</svg>
				Beats
			</a>
		</nav>
		{% endblock %}
		{# ── PAGE CONTENT ── #}
		{% block body %}{% endblock %}

	</body>
</html>