<!DOCTYPE html>
<html>
	<head>
		<meta charset="UTF-8">
		<title>
			{% block title %}Trackstar{% endblock %}
		</title>
		<link rel="icon" href="{{ asset('Logo.svg') }}" type="image/svg+xml">
		{% block stylesheets %}
			<link rel="stylesheet" href="{{ asset('css/app.css') }}">
			<style>
				* {
					margin: 0;
					padding: 0;
					box-sizing: border-box;
				}

				@import url("https://use.typekit.net/tqp0iic.css");

				*,
				*::before,
				*::after {
					box-sizing: border-box;
					margin: 0;
					padding: 0;
				}

				:root {
					--bg: #000000;
					--surface: #111113;
					--border: #2a2a2d;
					--orange: #ff5a00;
					--orange-h: #ff7020;
					--red: #e02434;
					--text: #ffffff;
					--muted: #8a8a8e;
					--input-bg: #3a3c41;

					--font-heading: 'futura-pt', 'Outfit', sans-serif;
					--font-subheading: 'sofia-pro', 'Outfit', sans-serif;
					--font-body: 'acumin-pro', 'Outfit', sans-serif;
				}

				h1, h2, h3, h4, h5, h6 {
					font-family: var(--font-heading);
					font-weight: 600;
					font-style: italic;
				}

				body {
					background-color: #1a1a1a;
					color: #ffffff;
					font-family: 'Arial', sans-serif;
					min-height: 100vh;
					display: flex;
					flex-direction: column;
				}

				/* ── NAVBAR ── */
				.navbar {
					display: flex;
					align-items: center;
					justify-content: space-between;
					padding: 14px 32px;
					background-color: #111111;
					border-bottom: 1px solid #2a2a2a;
					position: relative;
					z-index: 100;
				}

				.navbar-logo {
					display: flex;
					align-items: center;
					text-decoration: none;
				}

				.navbar-logo img {
					display: block;
					height: 32px;
					width: auto;
				}

				.navbar-search {
					flex: 1;
					max-width: 440px;
					margin: 0 40px;
					display: flex;
					align-items: center;
					gap: 8px;
				}

				.navbar-search-inner {
					position: relative;
					flex: 1;
				}

				.navbar-search-inner input {
					width: 100%;
					background-color: #2a2a2a;
					border: 1px solid #3a3a3a;
					border-radius: 6px;
					color: #ccc;
					font-size: 0.85rem;
					padding: 8px 14px 8px 36px;
					outline: none;
					transition: border-color 0.2s;
				}

				.navbar-search-inner input::placeholder { color: #666; }
				.navbar-search-inner input:focus { border-color: var(--orange); }

				.navbar-search-inner .search-icon {
					position: absolute;
					left: 10px;
					top: 50%;
					transform: translateY(-50%);
					color: #666;
					width: 16px;
					height: 16px;
					pointer-events: none;
				}

				.navbar-search-inner .search-icon svg {
					width: 16px;
					height: 16px;
					stroke: currentColor;
					fill: none;
					stroke-width: 2;
					stroke-linecap: round;
				}

				.navbar-search-btn {
					background: var(--orange);
					color: #fff;
					border: none;
					border-radius: 6px;
					padding: 8px 16px;
					font-size: 0.85rem;
					font-weight: 600;
					cursor: pointer;
					white-space: nowrap;
					transition: background 0.2s;
					flex-shrink: 0;
				}

				.navbar-search-btn:hover { background: var(--orange-h); }

				/* ── FILTER BUTTON ── */
				.filter-toggle-btn {
					width: 34px;
					height: 34px;
					background-color: #2a2a2a;
					border: 1px solid #3a3a3a;
					border-radius: 6px;
					display: flex;
					align-items: center;
					justify-content: center;
					cursor: pointer;
					color: #aaa;
					transition: all 0.2s;
					flex-shrink: 0;
					position: relative;
				}

				.filter-toggle-btn:hover,
				.filter-toggle-btn.is-open {
					border-color: var(--orange);
					color: var(--orange);
					background-color: rgba(255,90,0,0.08);
				}

				.filter-toggle-btn svg {
					width: 16px;
					height: 16px;
					fill: currentColor;
				}

				.filter-toggle-btn.has-active::after {
					content: '';
					position: absolute;
					top: 5px;
					right: 5px;
					width: 7px;
					height: 7px;
					background: var(--orange);
					border-radius: 50%;
					border: 2px solid #111;
				}

				/* ── FILTER PANEL ── */
				.filter-panel {
					position: absolute;
					top: calc(100% + 8px);
					left: 50%;
					transform: translateX(-50%) translateY(-8px);
					width: 560px;
					max-width: calc(100vw - 32px);
					background: #111111;
					border: 1px solid #2a2a2a;
					border-radius: 10px;
					box-shadow: 0 8px 40px rgba(0,0,0,0.7);
					z-index: 200;
					opacity: 0;
					pointer-events: none;
					transition: opacity 0.2s ease, transform 0.2s ease;
				}

				.filter-panel.is-open {
					opacity: 1;
					pointer-events: all;
					transform: translateX(-50%) translateY(0);
				}

				.filter-panel-header {
					display: flex;
					align-items: center;
					justify-content: space-between;
					padding: 14px 20px;
					border-bottom: 1px solid #1e1e1e;
				}

				.filter-panel-title {
					font-size: 0.78rem;
					font-weight: 700;
					letter-spacing: 0.08em;
					text-transform: uppercase;
					color: #666;
					font-family: var(--font-heading);
					font-style: italic;
				}

				.filter-panel-actions {
					display: flex;
					gap: 8px;
				}

				.filter-btn-reset {
					background: none;
					border: 1px solid #333;
					border-radius: 5px;
					color: #777;
					font-size: 0.78rem;
					padding: 5px 12px;
					cursor: pointer;
					transition: all 0.2s;
					font-family: var(--font-body);
				}

				.filter-btn-reset:hover { border-color: #555; color: #ccc; }

				.filter-btn-apply {
					background: var(--orange);
					border: none;
					border-radius: 5px;
					color: #fff;
					font-size: 0.78rem;
					font-weight: 600;
					padding: 5px 14px;
					cursor: pointer;
					transition: background 0.2s;
					font-family: var(--font-body);
				}

				.filter-btn-apply:hover { background: var(--orange-h); }

				.filter-panel-body {
					padding: 16px 20px 20px;
					display: grid;
					grid-template-columns: 1fr 1fr;
					gap: 18px 24px;
				}

				.filter-section {
					display: flex;
					flex-direction: column;
					gap: 8px;
				}

				.filter-section.full-width {
					grid-column: 1 / -1;
				}

				.filter-label {
					font-size: 0.68rem;
					font-weight: 700;
					letter-spacing: 0.07em;
					text-transform: uppercase;
					color: #555;
					font-family: var(--font-heading);
					font-style: italic;
				}

				.filter-options {
					display: flex;
					flex-wrap: wrap;
					gap: 6px;
				}

				.filter-chip {
					display: inline-flex;
					align-items: center;
					padding: 5px 10px;
					border-radius: 5px;
					border: 1px solid #2a2a2a;
					background: #1a1a1a;
					color: #aaa;
					font-size: 0.78rem;
					cursor: pointer;
					transition: all 0.15s;
					user-select: none;
				}

				.filter-chip input { display: none; }

				.filter-chip:hover { border-color: #3a3a3a; color: #ccc; }

				.filter-chip.is-selected {
					border-color: var(--orange);
					color: var(--orange);
					background: rgba(255,90,0,0.08);
				}

				.filter-stars {
					display: flex;
					gap: 2px;
					align-items: center;
				}

				.filter-star {
					font-size: 1.45rem;
					color: #333;
					cursor: pointer;
					transition: color 0.1s, transform 0.1s;
					line-height: 1;
				}

				.filter-star:hover { transform: scale(1.15); }
				.filter-star.is-active { color: var(--orange); }

				.filter-stars-hint {
					font-size: 0.72rem;
					color: #555;
					margin-left: 8px;
				}

				.filter-tags-input {
					width: 100%;
					background: #1a1a1a;
					border: 1px solid #2a2a2a;
					border-radius: 5px;
					color: #ccc;
					font-size: 0.8rem;
					padding: 7px 10px;
					outline: none;
					transition: border-color 0.2s;
					font-family: var(--font-body);
				}

				.filter-tags-input::placeholder { color: #3a3a3a; }
				.filter-tags-input:focus { border-color: #444; }

				.navbar-right {
					display: flex;
					align-items: center;
					gap: 16px;
				}

				.navbar-shop {
					color: #ffffff;
					text-decoration: none;
					font-size: 0.9rem;
					font-weight: 500;
					transition: color 0.2s;
				}

				.navbar-shop:hover { color: var(--orange); }

				.navbar-avatar {
					width: 34px;
					height: 34px;
					background-color: #2a2a2a;
					border: 1px solid #3a3a3a;
					border-radius: 50%;
					display: flex;
					align-items: center;
					justify-content: center;
					cursor: pointer;
					color: #aaa;
					font-size: 1rem;
					transition: border-color 0.2s;
				}

				.navbar-avatar:hover {
					border-color: var(--orange);
					color: var(--orange);
				}

				/* ── UPLOAD BUTTON ── */
				.navbar-upload-btn {
					width: 34px;
					height: 34px;
					background-color: #ff5a00;
					border-radius: 50%;
					display: flex;
					align-items: center;
					justify-content: center;
					color: #fff;
					font-size: 1.3rem;
					font-weight: 300;
					text-decoration: none;
					line-height: 1;
					transition: background 0.2s, transform 0.1s;
				}

				.navbar-upload-btn:hover {
					background-color: #e85000;
					transform: scale(1.08);
				}

				/* ── MENU BUTTON ── */
				.navbar-menu-btn {
					width: 34px;
					height: 34px;
					background: none;
					border: none;
					cursor: pointer;
					display: flex;
					flex-direction: column;
					align-items: center;
					justify-content: center;
					gap: 5px;
					padding: 4px;
					border-radius: 6px;
					transition: background-color 0.2s;
				}

				.navbar-menu-btn:hover {
					background-color: #2a2a2a;
				}

				.navbar-menu-btn span {
					display: block;
					width: 20px;
					height: 2px;
					background-color: #cccccc;
					border-radius: 2px;
					transition: all 0.3s ease;
					transform-origin: center;
				}

				.navbar-menu-btn.is-open span:nth-child(1) {
					transform: translateY(7px) rotate(45deg);
				}

				.navbar-menu-btn.is-open span:nth-child(2) {
					opacity: 0;
					transform: scaleX(0);
				}

				.navbar-menu-btn.is-open span:nth-child(3) {
					transform: translateY(-7px) rotate(-45deg);
				}

				.navbar-admin-btn {
					display: inline-flex;
					align-items: center;
					gap: 6px;
					padding: 6px 13px;
					border-radius: 5px;
					background: rgba(255, 90, 0, 0.1);
					border: 1px solid rgba(255, 90, 0, 0.3);
					color: var(--orange);
					text-decoration: none;
					font-size: 0.8rem;
					font-weight: 700;
					letter-spacing: 0.03em;
					font-family: var(--font-heading);
					font-style: italic;
					transition: all 0.2s;
				}

				.navbar-admin-btn:hover {
					background: rgba(255, 90, 0, 0.2);
					border-color: var(--orange);
					color: #ffffff;
				}

				/* ── SLIDE-IN OVERLAY ── */
				.menu-overlay {
					position: fixed;
					inset: 0;
					background-color: rgba(0, 0, 0, 0.55);
					z-index: 200;
					opacity: 0;
					pointer-events: none;
					transition: opacity 0.3s ease;
				}

				.menu-overlay.is-open {
					opacity: 1;
					pointer-events: all;
				}

				/* ── SLIDE-IN SIDEBAR ── */
				.menu-sidebar {
					position: fixed;
					top: 0;
					right: 0;
					width: 300px;
					height: 100vh;
					background-color: #111111;
					border-left: 1px solid #2a2a2a;
					z-index: 300;
					transform: translateX(100%);
					transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
					display: flex;
					flex-direction: column;
				}

				.menu-sidebar.is-open {
					transform: translateX(0);
				}

				/* ── SIDEBAR HEADER ── */
				.sidebar-header {
					display: flex;
					align-items: center;
					justify-content: space-between;
					padding: 18px 24px;
					border-bottom: 1px solid #2a2a2a;
				}

				.sidebar-header-title {
					font-size: 0.95rem;
					font-weight: 700;
					color: #ffffff;
					letter-spacing: 0.02em;
					text-transform: uppercase;
					font-family: var(--font-heading);
					font-style: italic;
				}

				.sidebar-close-btn {
					width: 30px;
					height: 30px;
					background: none;
					border: 1px solid #2a2a2a;
					border-radius: 6px;
					cursor: pointer;
					display: flex;
					align-items: center;
					justify-content: center;
					color: #888;
					font-size: 1.1rem;
					line-height: 1;
					transition: all 0.2s;
				}

				.sidebar-close-btn:hover {
					border-color: var(--orange);
					color: var(--orange);
				}

				/* ── SIDEBAR USER INFO ── */
				.sidebar-user {
					display: flex;
					align-items: center;
					gap: 14px;
					padding: 20px 24px;
					border-bottom: 1px solid #2a2a2a;
				}

				.sidebar-user-avatar {
					width: 46px;
					height: 46px;
					background: linear-gradient(135deg, var(--orange), #cc3a00);
					border-radius: 50%;
					display: flex;
					align-items: center;
					justify-content: center;
					font-size: 1.2rem;
					flex-shrink: 0;
				}

				.sidebar-user-name {
					font-size: 0.95rem;
					font-weight: 600;
					color: #ffffff;
					margin-bottom: 2px;
				}

				.sidebar-user-handle {
					font-size: 0.78rem;
					color: #666;
				}

				/* ── SIDEBAR NAV ── */
				.sidebar-nav {
					flex: 1;
					padding: 12px 0;
					overflow-y: auto;
				}

				.sidebar-nav-item {
					display: flex;
					align-items: center;
					gap: 14px;
					padding: 14px 24px;
					color: #cccccc;
					text-decoration: none;
					font-size: 0.9rem;
					font-weight: 500;
					transition: all 0.18s;
					cursor: pointer;
					border: none;
					background: none;
					width: 100%;
					text-align: left;
				}

				.sidebar-nav-item:hover {
					background-color: #1a1a1a;
					color: #ffffff;
				}

				.sidebar-nav-item:hover .sidebar-nav-icon {
					color: var(--orange);
				}

				.sidebar-nav-icon {
					width: 20px;
					height: 20px;
					display: flex;
					align-items: center;
					justify-content: center;
					color: #555;
					flex-shrink: 0;
					transition: color 0.18s;
				}

				.sidebar-nav-icon svg {
					width: 18px;
					height: 18px;
					fill: currentColor;
				}

				/* ── SIDEBAR DIVIDER ── */
				.sidebar-divider {
					height: 1px;
					background-color: #1e1e1e;
					margin: 8px 24px;
				}

				/* ── LOGOUT ITEM ── */
				.sidebar-nav-item.logout {
					color: #cc3333;
				}

				.sidebar-nav-item.logout .sidebar-nav-icon {
					color: #cc3333;
				}

				.sidebar-nav-item.logout:hover {
					background-color: rgba(224, 36, 52, 0.08);
					color: var(--red);
				}

				.sidebar-nav-item.logout:hover .sidebar-nav-icon {
					color: var(--red);
				}

				/* ── SUBNAV ── */
				.subnav {
					display: flex;
					align-items: center;
					justify-content: center;
					gap: 48px;
					padding: 14px 32px;
					background-color: #111111;
					border-bottom: 1px solid #2a2a2a;
				}

				.subnav a {
					color: #cccccc;
					text-decoration: none;
					font-size: 0.9rem;
					font-weight: 500;
					display: flex;
					align-items: center;
					gap: 7px;
					transition: color 0.2s;
				}

				.subnav a:hover { color: var(--orange-h); }
				.subnav a.active { color: var(--orange-h); }

				.subnav a svg {
					width: 15px;
					height: 15px;
					fill: currentColor;
				}

				/* ── MAIN ── */
				.main {
					flex: 1;
					padding: 48px 32px 64px;
					max-width: 1200px;
					margin: 0 auto;
					width: 100%;
				}

				.section-title {
					font-size: 1.75rem;
					font-weight: 700;
					text-align: center;
					margin-bottom: 40px;
					color: #ffffff;
				}

				/* ── GRID ── */
				.content-grid {
					display: grid;
					grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
					gap: 28px;
				}

				/* ── CARD ── */
				.card {
					background-color: #111111;
					border-radius: 8px;
					overflow: hidden;
					cursor: pointer;
					transition: transform 0.2s, box-shadow 0.2s;
				}

				.card:hover {
					transform: translateY(-4px);
					box-shadow: 0 8px 24px rgba(0, 0, 0, 0.5);
				}

				.card-cover {
					width: 100%;
					aspect-ratio: 1 / 1;
					object-fit: cover;
					display: block;
					background-color: #2a2a2a;
				}

				.card-cover-placeholder {
					width: 100%;
					aspect-ratio: 1 / 1;
					background: linear-gradient(135deg, #2a2a2a 0%, #1a1a1a 100%);
					display: flex;
					align-items: center;
					justify-content: center;
					color: #444;
					font-size: 2.5rem;
				}

				.card-body { padding: 12px 12px 14px; }

				.card-title {
					text-align: center;
					font-size: 0.85rem;
					font-weight: 600;
					color: #ffffff;
					margin-bottom: 3px;
					line-height: 1.35;
					white-space: nowrap;
					overflow: hidden;
					text-overflow: ellipsis;
				}

				.card-user {
					text-align: center;
					font-size: 0.78rem;
					color: #888888;
					margin-bottom: 6px;
				}

				.card-stats {
					display: flex;
					justify-content: center;
					align-items: center;
					gap: 32px;
					margin-top: 10px;
					margin-bottom: 8px;
					font-size: 0.85rem;
					color: #666;
				}

				.card-stat {
					display: flex;
					align-items: center;
					gap: 3px;
				}

				.card-stat svg {
					width: 14px;
					height: 14px;
					fill: currentColor;
					flex-shrink: 0;
				}

				.card-footer {
					display: flex;
					flex-wrap: wrap;
					justify-content: center;
					align-items: center;
					gap: 6px;
				}

				.card-tag-more {
					color: var(--muted);
					background-color: #2a2a2a;
				}

				.card-price {
					background-color: #2a2a2a;
					border-radius: 4px;
					padding: 4px 10px;
					font-size: 0.8rem;
					font-weight: 600;
					color: #ffffff;
					display: inline-flex;
					align-items: center;
					gap: 5px;
				}

				.card-price svg {
					width: 12px;
					height: 12px;
					fill: currentColor;
					color: #aaa;
				}

				.card-tag {
					align-items: center;
					text-align: center;
					font-size: 0.72rem;
					color: #666;
					background-color: #222;
					border-radius: 3px;
					padding: 3px 7px;
				}

				.empty-state {
					text-align: center;
					color: #555;
					padding: 80px 0;
					font-size: 1rem;
				}

				.tag-badge {
					display: inline-block;
					border: 1px solid var(--orange);
					color: var(--orange);
					border-radius: 5px;
					padding: 3px 10px;
					font-size: 0.8rem;
					margin: 2px;
				}

				/* ── FOOTER ── */
				footer {
					background-color: var(--surface);
					border-top: 1px solid var(--border);
					color: var(--muted);
					font-family: var(--font-body);
					font-size: 0.8rem;
					text-align: center;
					padding: 24px 32px;
				}

				footer a {
					color: var(--muted);
					text-decoration: none;
				}

				footer a:hover {
					color: var(--text);
				}
			</style>
		{% endblock %}

		{% block javascripts %}{% endblock %}
	</head>
	<body>

		{# ── NAVBAR ── außerhalb von block body, immer sichtbar #}
		{% block navbar %}
		<nav class="navbar">
			<a href="/home" class="navbar-logo">
				<img src="{{ asset('Logo.svg') }}" alt="TrackStar" height="32">
			</a>

			<form class="navbar-search" action="{{ path('app_search') }}" method="GET">
				<div class="navbar-search-inner">
					<span class="search-icon">
						<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
							<circle cx="11" cy="11" r="7"/>
							<line x1="21" y1="21" x2="16.65" y2="16.65"/>
						</svg>
					</span>
					<input type="text" name="q" placeholder="Titel, Beschreibung oder Autor …" value="{{ app.request.query.get('q') }}"/>
				</div>
				<button type="submit" class="navbar-search-btn">Suchen</button>
				<button type="button" class="filter-toggle-btn" id="filterToggle" aria-label="Filter">
					<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
						<path d="M3 17v2h6v-2H3zM3 5v2h10V5H3zm10 16v-2h8v-2h-8v-2h-2v6h2zM7 9v2H3v2h4v2h2V9H7zm14 4v-2H11v2h10zm-6-4h2V7h4V5h-4V3h-2v6z"/>
					</svg>
				</button>
			</form>

			{# ── FILTER PANEL ── #}
			<div class="filter-panel" id="filterPanel" role="dialog" aria-label="Filter">
				<div class="filter-panel-header">
					<span class="filter-panel-title">Filter &amp; Sortierung</span>
					<div class="filter-panel-actions">
						<button type="button" class="filter-btn-reset" id="filterReset">Zurücksetzen</button>
						<button type="button" class="filter-btn-apply" id="filterApply">Anwenden</button>
					</div>
				</div>
				<div class="filter-panel-body">

					<div class="filter-section">
						<div class="filter-label">Datum</div>
						<div class="filter-options">
							<label class="filter-chip"><input type="radio" name="filter-date" value="all"> Alle</label>
							<label class="filter-chip"><input type="radio" name="filter-date" value="week"> Letzte Woche</label>
							<label class="filter-chip"><input type="radio" name="filter-date" value="month"> Letzter Monat</label>
							<label class="filter-chip"><input type="radio" name="filter-date" value="year"> Letztes Jahr</label>
						</div>
					</div>

					<div class="filter-section">
						<div class="filter-label">Sortieren nach</div>
						<div class="filter-options">
							<label class="filter-chip"><input type="radio" name="filter-sort" value="downloads"> Downloads</label>
							<label class="filter-chip"><input type="radio" name="filter-sort" value="favorites"> Favoriten</label>
							<label class="filter-chip"><input type="radio" name="filter-sort" value="rating"> Bewertung</label>
						</div>
					</div>

					<div class="filter-section">
						<div class="filter-label">Kategorie</div>
						<div class="filter-options">
							<label class="filter-chip"><input type="checkbox" name="filter-category" value="Tracks"> Tracks</label>
							<label class="filter-chip"><input type="checkbox" name="filter-category" value="Beats"> Beats</label>
							<label class="filter-chip"><input type="checkbox" name="filter-category" value="Sound Kits"> Sound Kits</label>
							<label class="filter-chip"><input type="checkbox" name="filter-category" value="Samples"> Samples</label>
						</div>
					</div>

					<div class="filter-section">
						<div class="filter-label">Mindest-Bewertung</div>
						<div class="filter-stars" id="filterStars">
							<span class="filter-star" data-value="1">&#9733;</span>
							<span class="filter-star" data-value="2">&#9733;</span>
							<span class="filter-star" data-value="3">&#9733;</span>
							<span class="filter-star" data-value="4">&#9733;</span>
							<span class="filter-star" data-value="5">&#9733;</span>
							<span class="filter-stars-hint" id="filterStarsHint">Alle</span>
						</div>
					</div>

					<div class="filter-section full-width">
						<div class="filter-label">Tags <span style="font-style:normal;font-weight:400;text-transform:none;letter-spacing:0;color:#444;">(kommagetrennt)</span></div>
						<input type="text" class="filter-tags-input" id="filterTagsInput" placeholder="z. B. melodic, trap, 808 …">
					</div>

				</div>
			</div>

			<div class="navbar-right">
				{% if app.user and 'ROLE_ADMIN' in app.user.roles %}
				<a href="{{ path('app_admin_users') }}" class="navbar-admin-btn">
					<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor">
						<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2h16zm-5-10a4 4 0 1 0 0-8 4 4 0 0 0 0 8zm6 2v2h2v-2h2v-2h-2v-2h-2v2h-2v2h2z"/>
					</svg>
					Admin
				</a>
				{% endif %}
				<a href="/upload" class="navbar-upload-btn">+</a>
				<a href="/deine-inhalte" class="navbar-shop">Deine Inhalte</a>

				{# ── MENU TOGGLE BUTTON ── #}
				<button class="navbar-menu-btn" id="menuToggle" aria-label="Menü öffnen">
					<span></span>
					<span></span>
					<span></span>
				</button>
			</div>
		</nav>

		{# ── OVERLAY ── #}
		<div class="menu-overlay" id="menuOverlay"></div>

		{# ── SLIDE-IN SIDEBAR ── #}
		<aside class="menu-sidebar" id="menuSidebar" aria-hidden="true">

			<div class="sidebar-header">
				<span class="sidebar-header-title">Menü</span>
				<button class="sidebar-close-btn" id="menuClose" aria-label="Menü schließen">&#x2715;</button>
			</div>

			<div class="sidebar-user">
				<div class="sidebar-user-avatar">&#128100;</div>
				<div>
					{% if app.user %}
						<div class="sidebar-user-name">{{ app.user.username }}</div>
						<div class="sidebar-user-handle">{{ app.user.email }}</div>
					{% endif %}
				</div>
			</div>

			<nav class="sidebar-nav">

				{% if app.user %}
				<a href="{{ path('app_userprofile', {'username': app.user.username}) }}" class="sidebar-nav-item">
					<span class="sidebar-nav-icon">
						<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
							<path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/>
						</svg>
					</span>
					Benutzerprofil
				</a>
				{% endif %}

				{% if app.user %}
				<a href="{{ path('app_user_management') }}" class="sidebar-nav-item">
					<span class="sidebar-nav-icon">
						<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
							<path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/>
						</svg>
					</span>
					Kontodetails
				</a>
				{% endif %}

				{% if app.user and 'ROLE_ADMIN' in app.user.roles %}
				<div class="sidebar-divider"></div>
				<a href="{{ path('app_admin_users') }}" class="sidebar-nav-item">
					<span class="sidebar-nav-icon">
						<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
							<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2h16zm-5-10a4 4 0 1 0 0-8 4 4 0 0 0 0 8zm6 2v2h2v-2h2v-2h-2v-2h-2v2h-2v2h2z"/>
						</svg>
					</span>
					Admin Dashboard
				</a>
				<div class="sidebar-divider"></div>
				{% endif %}

				<a href="{{ path('app_favorites') }}" class="sidebar-nav-item">
					<span class="sidebar-nav-icon">
						<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
							<path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
						</svg>
					</span>
					Favorisierte Inhalte
				</a>

				<div class="sidebar-divider"></div>

				<a href="/logout" class="sidebar-nav-item logout">
					<span class="sidebar-nav-icon">
						<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
							<path d="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5-5-5zM4 5h8V3H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h8v-2H4V5z"/>
						</svg>
					</span>
					Abmelden
				</a>

			</nav>
		</aside>

		{# ── SUBNAV ── #}
		<nav class="subnav">
			<a href="/entdecke-tracks" class="{{ app.request.pathinfo == '/entdecke-tracks' ? 'active' : '' }}">
				<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
					<path d="M12 3v10.55A4 4 0 1 0 14 17V7h4V3h-6z"/>
				</svg>
				Tracks
			</a>
			<a href="/entdecke-sound-kits" class="{{ app.request.pathinfo == '/entdecke-sound-kits' ? 'active' : '' }}">
				<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
					<path d="M20 2H4a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2zm-9 13H9V9h2v6zm4 0h-2V9h2v6z"/>
				</svg>
				SoundKits
			</a>
			<a href="/entdecke-loop-und-samples" class="{{ app.request.pathinfo == '/entdecke-loop-und-samples' ? 'active' : '' }}">
				<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
					<path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3A4.5 4.5 0 0 0 14 7.97v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/>
				</svg>
				Loops&amp;Samples
			</a>
			<a href="/entdecke-beats" class="{{ app.request.pathinfo == '/entdecke-beats' ? 'active' : '' }}">
				<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
					<path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z"/>
				</svg>
				Beats
			</a>
		</nav>

		{# ── FILTER JAVASCRIPT ── #}
		<script>
		(function () {
			const filterToggle = document.getElementById('filterToggle');
			const filterPanel  = document.getElementById('filterPanel');
			const filterApply  = document.getElementById('filterApply');
			const filterReset  = document.getElementById('filterReset');
			const filterStars  = document.getElementById('filterStars');
			const filterStarsHint = document.getElementById('filterStarsHint');

			let filterRatingVal = 0;

			/* ── Stars ── */
			function updateFilterStars(rating) {
				filterRatingVal = rating;
				filterStars.querySelectorAll('.filter-star').forEach(function (s) {
					s.classList.toggle('is-active', parseInt(s.dataset.value) <= rating);
				});
				filterStarsHint.textContent = rating > 0 ? rating + '+ Sterne' : 'Alle';
			}

			filterStars.querySelectorAll('.filter-star').forEach(function (star) {
				star.addEventListener('click', function () {
					var val = parseInt(star.dataset.value);
					updateFilterStars(filterRatingVal === val ? 0 : val);
				});
				star.addEventListener('mouseenter', function () {
					var val = parseInt(star.dataset.value);
					filterStars.querySelectorAll('.filter-star').forEach(function (s) {
						s.classList.toggle('is-active', parseInt(s.dataset.value) <= val);
					});
				});
				star.addEventListener('mouseleave', function () {
					updateFilterStars(filterRatingVal);
				});
			});

			/* ── Chip selection ── */
			function updateChips() {
				filterPanel.querySelectorAll('.filter-chip').forEach(function (chip) {
					var input = chip.querySelector('input');
					if (input) chip.classList.toggle('is-selected', input.checked);
				});
			}

			filterPanel.querySelectorAll('.filter-chip input').forEach(function (input) {
				input.addEventListener('change', updateChips);
			});

			/* ── Toggle panel ── */
			filterToggle.addEventListener('click', function (e) {
				e.stopPropagation();
				var open = filterPanel.classList.toggle('is-open');
				filterToggle.classList.toggle('is-open', open);
			});

			document.addEventListener('click', function (e) {
				if (!filterPanel.contains(e.target) && !filterToggle.contains(e.target)) {
					filterPanel.classList.remove('is-open');
					filterToggle.classList.remove('is-open');
				}
			});

			document.addEventListener('keydown', function (e) {
				if (e.key === 'Escape') {
					filterPanel.classList.remove('is-open');
					filterToggle.classList.remove('is-open');
				}
			});

			/* ── Build filter URL (shared by apply + search form) ── */
			function buildFilterUrl(q, dateRange, categories, tags, ratingVal, sort) {
				var url = new URL('/suche', window.location.origin);
				if (q) url.searchParams.set('q', q);
				if (dateRange && dateRange !== 'all') url.searchParams.set('date_range', dateRange);
				categories.forEach(function (c) { url.searchParams.append('categories[]', c); });
				if (tags.length > 0) url.searchParams.set('tags', tags.join(','));
				if (ratingVal > 0) url.searchParams.set('min_rating', ratingVal);
				if (sort) url.searchParams.set('sort', sort);
				return url.toString();
			}

			function readPanelState() {
				return {
					dateRange:  (filterPanel.querySelector('input[name="filter-date"]:checked') || {}).value || 'all',
					categories: Array.from(filterPanel.querySelectorAll('input[name="filter-category"]:checked')).map(function (el) { return el.value; }),
					tags:       document.getElementById('filterTagsInput').value.split(',').map(function (t) { return t.trim(); }).filter(Boolean),
					sort:       (filterPanel.querySelector('input[name="filter-sort"]:checked') || {}).value || '',
				};
			}

			/* ── Apply filters ── */
			filterApply.addEventListener('click', function () {
				var q   = document.querySelector('.navbar-search input[name="q"]').value.trim();
				var s   = readPanelState();
				window.location.href = buildFilterUrl(q, s.dateRange, s.categories, s.tags, filterRatingVal, s.sort);
			});

			/* ── Search form: preserve active filters ── */
			var searchForm = document.querySelector('.navbar-search');
			if (searchForm) {
				searchForm.addEventListener('submit', function (e) {
					e.preventDefault();
					var q = searchForm.querySelector('input[name="q"]').value.trim();
					var s = readPanelState();
					window.location.href = buildFilterUrl(q, s.dateRange, s.categories, s.tags, filterRatingVal, s.sort);
				});
			}

			/* ── Reset ── */
			filterReset.addEventListener('click', function () {
				var q = document.querySelector('.navbar-search input[name="q"]').value.trim();
				var url = new URL('/suche', window.location.origin);
				if (q) url.searchParams.set('q', q);
				window.location.href = url.toString();
			});

			/* ── Init from URL ── */
			(function initFromUrl() {
				var params = new URLSearchParams(window.location.search);

				var dateRange = params.get('date_range') || 'all';
				var dateRadio = filterPanel.querySelector('input[name="filter-date"][value="' + dateRange + '"]');
				if (dateRadio) dateRadio.checked = true;
				else {
					var allRadio = filterPanel.querySelector('input[name="filter-date"][value="all"]');
					if (allRadio) allRadio.checked = true;
				}

				var activeCategories = params.getAll('categories[]');
				filterPanel.querySelectorAll('input[name="filter-category"]').forEach(function (cb) {
					cb.checked = activeCategories.includes(cb.value);
				});

				var tagsStr = params.get('tags') || '';
				document.getElementById('filterTagsInput').value = tagsStr;

				var minRating = parseInt(params.get('min_rating')) || 0;
				updateFilterStars(minRating);

				var sort = params.get('sort') || '';
				var sortRadio = sort ? filterPanel.querySelector('input[name="filter-sort"][value="' + sort + '"]') : null;
				if (sortRadio) sortRadio.checked = true;

				updateChips();

				var hasActive = dateRange !== 'all' || activeCategories.length > 0 || tagsStr !== '' || minRating > 0 || sort !== '';
				filterToggle.classList.toggle('has-active', hasActive);
			})();
		})();
		</script>

		{# ── MENU JAVASCRIPT ── #}
		<script>
			(function () {
				const toggle   = document.getElementById('menuToggle');
				const sidebar  = document.getElementById('menuSidebar');
				const overlay  = document.getElementById('menuOverlay');
				const closeBtn = document.getElementById('menuClose');

				function openMenu() {
					sidebar.classList.add('is-open');
					overlay.classList.add('is-open');
					toggle.classList.add('is-open');
					sidebar.setAttribute('aria-hidden', 'false');
					toggle.setAttribute('aria-label', 'Menü schließen');
					document.body.style.overflow = 'hidden';
				}

				function closeMenu() {
					sidebar.classList.remove('is-open');
					overlay.classList.remove('is-open');
					toggle.classList.remove('is-open');
					sidebar.setAttribute('aria-hidden', 'true');
					toggle.setAttribute('aria-label', 'Menü öffnen');
					document.body.style.overflow = '';
				}

				toggle.addEventListener('click', function () {
					sidebar.classList.contains('is-open') ? closeMenu() : openMenu();
				});

				closeBtn.addEventListener('click', closeMenu);
				overlay.addEventListener('click', closeMenu);

				document.addEventListener('keydown', function (e) {
					if (e.key === 'Escape') closeMenu();
				});
			})();
		</script>
		{% endblock navbar %}

		{# ── PAGE CONTENT ── Kind-Templates füllen diesen Block #}
		{% block body %}{% endblock %}

		<script>
			document.addEventListener('DOMContentLoaded', function () {
				document.querySelectorAll('.card-footer').forEach(function (footer) {
					var tags = Array.from(footer.querySelectorAll('.card-tag'));
					if (tags.length === 0) return;

					var baseTop = tags[0].offsetTop;
					var overflowStart = tags.findIndex(function (t) { return t.offsetTop > baseTop; });
					if (overflowStart === -1) return;

					var hiddenCount = tags.length - overflowStart;
					tags.slice(overflowStart).forEach(function (t) { t.style.display = 'none'; });

					var badge = document.createElement('span');
					badge.className = 'card-tag card-tag-more';
					badge.textContent = '+' + hiddenCount;
					footer.appendChild(badge);

					// if the badge itself wraps, pull one more tag into the hidden count
					if (badge.offsetTop > baseTop && overflowStart > 0) {
						tags[overflowStart - 1].style.display = 'none';
						hiddenCount++;
						badge.textContent = '+' + hiddenCount;
					}
				});
			});
		</script>

		<footer>
			<span>© {{ "now"|date("Y") }} Trackstar. Alle Rechte vorbehalten.</span>
			&nbsp;·&nbsp;
			<a href="/impressum">Impressum &amp; Datenschutz</a>
		</footer>

	</body>
</html>
