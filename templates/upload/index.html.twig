{% extends 'base.html.twig' %}

{% block title %}Upload – TrackStar{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .ts-upload-wrapper {
        min-height: calc(100vh - 120px);
        display: flex;
        align-items: flex-start;
        justify-content: center;
        padding: 3rem 1rem 4rem;
    }

    .ts-upload-card {
        width: 100%;
        max-width: 680px;
    }

    .ts-upload-header {
        margin-bottom: 2.5rem;
    }

    .ts-upload-header h1 {
        font-family: 'Inter', sans-serif;
        font-size: 2rem;
        font-weight: 800;
        color: #ffffff;
        margin: 0 0 0.4rem 0;
        letter-spacing: -0.03em;
    }

    .ts-upload-header h1 span {
        color: #ff6b1a;
    }

    .ts-upload-header p {
        color: #888;
        font-size: 0.95rem;
        margin: 0;
    }

    .ts-field {
        margin-bottom: 1.5rem;
    }

    .ts-field label {
        display: block;
        font-size: 0.78rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #aaa;
        margin-bottom: 0.5rem;
    }

    .ts-field .ts-input,
    .ts-field input[type="text"],
    .ts-field textarea,
    .ts-field select {
        width: 100%;
        background: #1a1a1a;
        border: 1px solid #2a2a2a;
        border-radius: 8px;
        color: #fff;
        font-size: 0.95rem;
        padding: 0.75rem 1rem;
        transition: border-color 0.2s, box-shadow 0.2s;
        outline: none;
        box-sizing: border-box;
        font-family: inherit;
    }

    .ts-field .ts-input:focus,
    .ts-field input[type="text"]:focus,
    .ts-field textarea:focus,
    .ts-field select:focus {
        border-color: #ff6b1a;
        box-shadow: 0 0 0 3px rgba(255, 107, 26, 0.12);
    }

    .ts-field select option {
        background: #1a1a1a;
        color: #fff;
    }

    .ts-field textarea {
        resize: vertical;
        min-height: 100px;
    }

    .ts-two-col {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.25rem;
    }

    /* Drop zones */
    .ts-drop-zone {
        border: 1.5px dashed #2a2a2a;
        border-radius: 12px;
        padding: 2rem 1.5rem;
        text-align: center;
        cursor: pointer;
        transition: border-color 0.2s, background 0.2s;
        background: #111;
        position: relative;
    }

    .ts-drop-zone:hover,
    .ts-drop-zone.drag-over {
        border-color: #ff6b1a;
        background: rgba(255, 107, 26, 0.04);
    }

    .ts-drop-zone input[type="file"] {
        position: absolute;
        inset: 0;
        opacity: 0;
        cursor: pointer;
        width: 100%;
        height: 100%;
    }

    .ts-drop-zone-icon {
        width: 40px;
        height: 40px;
        margin: 0 auto 0.75rem;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .ts-drop-zone-icon.audio-icon {
        background: rgba(255, 107, 26, 0.12);
        color: #ff6b1a;
    }

    .ts-drop-zone-icon.image-icon {
        background: rgba(120, 80, 255, 0.12);
        color: #7850ff;
    }

    .ts-drop-zone-icon svg {
        width: 20px;
        height: 20px;
    }

    .ts-drop-zone-title {
        font-size: 0.9rem;
        font-weight: 600;
        color: #ddd;
        margin-bottom: 0.25rem;
    }

    .ts-drop-zone-sub {
        font-size: 0.78rem;
        color: #666;
    }

    .ts-drop-zone-preview {
        margin-top: 0.75rem;
        font-size: 0.8rem;
        color: #ff6b1a;
        font-weight: 500;
        display: none;
    }

    .ts-drop-zone-preview.visible {
        display: block;
    }

    /* Divider */
    .ts-divider {
        border: none;
        border-top: 1px solid #1e1e1e;
        margin: 2rem 0;
    }

    /* Submit button */
    .ts-submit-btn {
        width: 100%;
        padding: 0.9rem 2rem;
        background: #ff6b1a;
        color: #fff;
        border: none;
        border-radius: 8px;
        font-size: 1rem;
        font-weight: 700;
        cursor: pointer;
        transition: background 0.2s, transform 0.1s;
        letter-spacing: 0.01em;
        margin-top: 0.5rem;
    }

    .ts-submit-btn:hover {
        background: #e85c0d;
    }

    .ts-submit-btn:active {
        transform: scale(0.99);
    }

    /* Flash messages */
    .ts-flash {
        padding: 0.85rem 1.2rem;
        border-radius: 8px;
        margin-bottom: 1.5rem;
        font-size: 0.9rem;
        font-weight: 500;
    }

    .ts-flash.success {
        background: rgba(34, 197, 94, 0.12);
        color: #22c55e;
        border: 1px solid rgba(34, 197, 94, 0.2);
    }

    .ts-flash.error {
        background: rgba(239, 68, 68, 0.12);
        color: #ef4444;
        border: 1px solid rgba(239, 68, 68, 0.2);
    }

    /* Errors */
    .ts-error {
        font-size: 0.78rem;
        color: #ef4444;
        margin-top: 0.35rem;
    }

    .ts-field input.is-invalid,
    .ts-field textarea.is-invalid,
    .ts-field select.is-invalid {
        border-color: #ef4444;
    }

    @media (max-width: 600px) {
        .ts-two-col {
            grid-template-columns: 1fr;
        }
        .ts-upload-header h1 {
            font-size: 1.5rem;
        }
    }
</style>
{% endblock %}

{% block body %}
<div class="ts-upload-wrapper">
    <div class="ts-upload-card">

        <div class="ts-upload-header">
            <h1>Neuer <span>Upload</span></h1>
            <p>Lade deinen Beat, Track oder dein Sample hoch und teile es mit der Community.</p>
        </div>

        {# Flash messages #}
        {% for message in app.flashes('success') %}
            <div class="ts-flash success">✓ {{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="ts-flash error">✗ {{ message }}</div>
        {% endfor %}

        {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'enctype': 'multipart/form-data', 'id': 'upload-form'}}) }}

        {# Title #}
        <div class="ts-field">
            {{ form_label(form.title) }}
            {{ form_widget(form.title) }}
            {{ form_errors(form.title) }}
        </div>

        {# Description #}
        <div class="ts-field">
            {{ form_label(form.description) }}
            {{ form_widget(form.description) }}
            {{ form_errors(form.description) }}
        </div>

        {# Category + Tag side by side #}
        <div class="ts-two-col">
            <div class="ts-field">
                {{ form_label(form.type) }}
                {{ form_widget(form.type) }}
                {{ form_errors(form.type) }}
            </div>
            <div class="ts-field">
                {{ form_label(form.fk_tag) }}
                {{ form_widget(form.fk_tag) }}
                {{ form_errors(form.fk_tag) }}
            </div>
        </div>

        <hr class="ts-divider">

        {# File Uploads #}
        <div class="ts-two-col">

            {# Audio file drop zone #}
            <div class="ts-field">
                <label>Audio-Datei</label>
                <div class="ts-drop-zone" id="audio-drop">
                    {{ form_widget(form.audioFile) }}
                    <div class="ts-drop-zone-icon audio-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M9 18V5l12-2v13"/>
                            <circle cx="6" cy="18" r="3"/>
                            <circle cx="18" cy="16" r="3"/>
                        </svg>
                    </div>
                    <div class="ts-drop-zone-title">Beat / Track hochladen</div>
                    <div class="ts-drop-zone-sub">MP3, WAV, FLAC – max. 50 MB</div>
                    <div class="ts-drop-zone-preview" id="audio-preview"></div>
                </div>
                {{ form_errors(form.audioFile) }}
            </div>

            {# Cover image drop zone #}
            <div class="ts-field">
                <label>Titelbild</label>
                <div class="ts-drop-zone" id="image-drop">
                    {{ form_widget(form.imageFile) }}
                    <div class="ts-drop-zone-icon image-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="3" width="18" height="18" rx="2"/>
                            <circle cx="8.5" cy="8.5" r="1.5"/>
                            <polyline points="21 15 16 10 5 21"/>
                        </svg>
                    </div>
                    <div class="ts-drop-zone-title">Cover-Bild hochladen</div>
                    <div class="ts-drop-zone-sub">JPG, PNG, WEBP – max. 5 MB</div>
                    <div class="ts-drop-zone-preview" id="image-preview"></div>
                </div>
                {{ form_errors(form.imageFile) }}
            </div>

        </div>

        <button type="submit" class="ts-submit-btn">
            Upload starten →
        </button>

        {{ form_end(form) }}

    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function () {
    function setupDropZone(zoneId, inputSelector, previewId, isImage) {
        const zone = document.getElementById(zoneId);
        const input = zone.querySelector('input[type="file"]');
        const preview = document.getElementById(previewId);

        if (!zone || !input || !preview) return;

        ['dragenter', 'dragover'].forEach(e => {
            zone.addEventListener(e, ev => {
                ev.preventDefault();
                zone.classList.add('drag-over');
            });
        });

        ['dragleave', 'drop'].forEach(e => {
            zone.addEventListener(e, ev => {
                ev.preventDefault();
                zone.classList.remove('drag-over');
            });
        });

        zone.addEventListener('drop', ev => {
            const files = ev.dataTransfer.files;
            if (files.length) {
                const dt = new DataTransfer();
                dt.items.add(files[0]);
                input.files = dt.files;
                showPreview(files[0]);
            }
        });

        input.addEventListener('change', () => {
            if (input.files.length) showPreview(input.files[0]);
        });

        function showPreview(file) {
            if (isImage && file.type.startsWith('image/')) {
                const reader = new FileReader();
                reader.onload = e => {
                    preview.innerHTML = '<img src="' + e.target.result + '" style="width:100%;height:80px;object-fit:cover;border-radius:6px;margin-top:8px;">';
                    preview.classList.add('visible');
                };
                reader.readAsDataURL(file);
            } else {
                const name = file.name.length > 30 ? file.name.substring(0, 27) + '...' : file.name;
                preview.textContent = '✓ ' + name;
                preview.classList.add('visible');
            }
        }
    }

    setupDropZone('audio-drop', null, 'audio-preview', false);
    setupDropZone('image-drop', null, 'image-preview', true);
});
</script>
{% endblock %}
