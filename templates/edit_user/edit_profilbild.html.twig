{% extends 'user_management/index.html.twig' %}

{% block title %}Profilbild ändern{% endblock %}

{% block ku_content %}
  <a href="{{ path('app_user_management') }}" class="ku-back">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px;"><polyline points="15 18 9 12 15 6"/></svg>
    zurück zu Kontodetails
  </a>

  <h1 class="ku-title" style="margin-top:12px;">Profilbild ändern</h1>

  {% for msg in app.flashes('warning') %}
    <div class="ku-flash warning">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      {{ msg }}
    </div>
  {% endfor %}

  <div class="ku-card">

    <div style="margin-bottom: 20px; padding-bottom: 20px; border-bottom: 1px solid #2a2a2a;">
      <div style="font-size:13px; color:#aaa; margin-bottom:12px; font-weight:600;">Aktuelles Profilbild</div>
      {% if user_data.profilePicture %}
        <img
          src="{{ asset(user_data.profilePicture) }}"
          alt="Profilbild"
          style="width:96px; height:96px; border-radius:50%; object-fit:cover; border:2px solid #3a3a3a;"
        />
      {% else %}
        <div style="width:96px; height:96px; border-radius:50%; background:linear-gradient(135deg,#e85d04,#cc3a00); display:flex; align-items:center; justify-content:center; font-size:2.2rem; font-weight:700; color:#fff;">
          {{ user_data.username|first|upper }}
        </div>
      {% endif %}
    </div>

    <div style="font-size:13px; color:#aaa; margin-bottom:8px; font-weight:600;">Neues Profilbild hochladen</div>
    <div style="font-size:12px; color:#666; margin-bottom:20px;">JPG, PNG oder WEBP · max. 5 MB</div>

    {{ form_start(form, { attr: { enctype: 'multipart/form-data' } }) }}
      {% set f = form.profilePicture %}

      <div style="display:flex; align-items:flex-start; gap:24px; margin-bottom:20px;">

        {# Preview circle #}
        <div id="preview-wrap" style="flex-shrink:0;">
          <div id="preview-placeholder" style="width:96px; height:96px; border-radius:50%; background:#2a2a2a; border:2px dashed #3a3a3a; display:flex; align-items:center; justify-content:center;">
            <svg viewBox="0 0 24 24" fill="none" stroke="#555" stroke-width="1.5" style="width:32px;height:32px;">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
              <polyline points="17 8 12 3 7 8"/>
              <line x1="12" y1="3" x2="12" y2="15"/>
            </svg>
          </div>
          <img id="preview-img" src="" alt="Vorschau"
            style="display:none; width:96px; height:96px; border-radius:50%; object-fit:cover; border:2px solid #e85d04;" />
        </div>

        {# File input styled as a drop zone #}
        <div style="flex:1;">
          <label for="{{ f.vars.id }}" id="drop-zone"
            style="display:flex; flex-direction:column; align-items:center; justify-content:center; gap:8px; padding:24px 16px; border:2px dashed #3a3a3a; border-radius:12px; cursor:pointer; transition:border-color .2s, background .2s;">
            <svg viewBox="0 0 24 24" fill="none" stroke="#777" stroke-width="1.5" style="width:28px;height:28px;">
              <rect x="3" y="3" width="18" height="18" rx="3"/>
              <path d="M3 9l4-4 4 4 4-4 4 4"/>
              <path d="M3 15h18"/>
            </svg>
            <span id="drop-label" style="font-size:13px; color:#777; text-align:center;">Bild auswählen oder hierher ziehen</span>
          </label>
          <div class="ku-field-wrap{{ f.vars.errors|length ? ' has-error' : '' }}" style="margin:0;">
            {{ form_widget(f, { attr: { style: 'display:none;', id: f.vars.id, accept: 'image/jpeg,image/png,image/webp' } }) }}
            {% if f.vars.errors|length %}
              <ul class="ku-field-errors" style="margin-top:6px;">
                {% for error in f.vars.errors %}<li>{{ error.message }}</li>{% endfor %}
              </ul>
            {% endif %}
          </div>
        </div>

      </div>

      <div style="display:flex; justify-content:flex-end; gap:10px; margin-top:10px;">
        <a href="{{ path('app_user_management') }}" class="ku-nav-btn" style="width:auto;">abbrechen</a>
        <button type="submit" class="ku-nav-btn active" style="width:auto;">Speichern</button>
      </div>
    {{ form_end(form) }}

  <script>
    (function () {
      const input       = document.getElementById('{{ f.vars.id }}');
      const dropZone    = document.getElementById('drop-zone');
      const dropLabel   = document.getElementById('drop-label');
      const placeholder = document.getElementById('preview-placeholder');
      const previewImg  = document.getElementById('preview-img');

      function showPreview(file) {
        if (!file || !file.type.startsWith('image/')) return;
        const reader = new FileReader();
        reader.onload = function (e) {
          previewImg.src = e.target.result;
          previewImg.style.display = 'block';
          placeholder.style.display = 'none';
          dropLabel.textContent = file.name;
          dropZone.style.borderColor = '#e85d04';
          dropZone.style.background  = 'rgba(232,93,4,0.06)';
        };
        reader.readAsDataURL(file);
      }

      input.addEventListener('change', function () {
        showPreview(this.files[0]);
      });

      dropZone.addEventListener('dragover', function (e) {
        e.preventDefault();
        this.style.borderColor = '#e85d04';
        this.style.background  = 'rgba(232,93,4,0.06)';
      });

      dropZone.addEventListener('dragleave', function () {
        if (!previewImg.src) {
          this.style.borderColor = '#3a3a3a';
          this.style.background  = '';
        }
      });

      dropZone.addEventListener('drop', function (e) {
        e.preventDefault();
        const file = e.dataTransfer.files[0];
        if (file) {
          const dt = new DataTransfer();
          dt.items.add(file);
          input.files = dt.files;
          showPreview(file);
        }
      });
    })();
  </script>
  </div>
{% endblock %}
