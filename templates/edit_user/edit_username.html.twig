{% extends 'base.html.twig' %}

{% block title %}Benutzer bearbeiten{% endblock %}

{% block body %}
{{parent()}}
<style>
    .form-wrapper { margin: 2em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
    .form-wrapper label { font-weight: bold; margin-bottom: 5px; display: block; }
    .form-wrapper input { width: 100%; padding: 10px; margin-bottom: 1em; border-radius: 5px; border: 1px solid #ccc; }
    .form-wrapper button { padding: 10px 20px; background-color: #007bff; color: white; border: none; border-radius: 5px; cursor: pointer; }
    .form-wrapper button:hover { background-color: #0056b3; }
    .error { color: red; font-size: 14px; }
</style>

<div class="form-wrapper">
    <h1>Benutzer bearbeiten</h1>

    {# Wenn Fehler vorhanden sind, zeige sie an #}
    {% for error in form.vars.errors %}
        <div class="error">{{ error.message }}</div>
    {% endfor %}

    {# Das Formular anzeigen #}
    {{ form_start(form) }}
        <div>
            {{ form_row(form.username) }}
        </div>
        <div>
            <button type="submit">Speichern</button>
        </div>
    {{ form_end(form) }}
</div>
{% endblock %}