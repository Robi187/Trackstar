{% extends 'base.html.twig' %}

{% block title %}Benutzer bearbeiten{% endblock %}

{% block body %}
{{parent()}}
<style>
    .form-wrapper { margin: 2em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
    .form-wrapper label { font-weight: bold; margin-bottom: 5px; display: block; }
    .form-wrapper input { width: 100%; padding: 10px; margin-bottom: 1em; border-radius: 5px; border: 1px solid #ccc; }
    .form-wrapper button { padding: 10px 20px; background-color: #007bff; color: white; border: none; border-radius: 5px; cursor: pointer; }
    .form-wrapper button:hover { background-color: #0056b3; }
    .error { color: red; font-size: 14px; }
    .alert-warning { background-color: #fff3cd; border: 1px solid #ffc107; color: #856404; padding: 10px; border-radius: 5px; margin-bottom: 1em; }
    .alert-success { background-color: #d4edda; border: 1px solid #28a745; color: #155724; padding: 10px; border-radius: 5px; margin-bottom: 1em; }
</style>

<div class="form-wrapper">
    <h1>Passwort bearbeiten</h1>

    {# Flash Messages #}
    {% for message in app.flashes('warning') %}
        <div class="alert-warning">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('success') %}
        <div class="alert-success">{{ message }}</div>
    {% endfor %}

    {{ form_start(form) }}
        <div>
            {{ form_row(form.password) }}
        </div>
        <div>
            <button type="submit">Speichern</button>
            <a href="{{ path('app_user_management') }}" class="ku-nav-btn">Abbrechen</a>
        </div>
    {{ form_end(form) }}
</div>
{% endblock %}