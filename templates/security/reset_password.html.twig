{% extends 'base.html.twig' %}

{% block title %}Neues Passwort – TrackStar{% endblock %}

{% block stylesheets %}
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
<style>
  @import url("https://use.typekit.net/tqp0iic.css");

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:        #000000;
    --surface:   #111113;
    --border:    #2a2a2d;
    --orange:    #ff5a00;
    --orange-h:  #ff7020;
    --text:      #ffffff;
    --muted:     #8a8a8e;
    --input-bg:  #3a3c41;
    --font-heading:    'futura-pt', 'Outfit', sans-serif;
    --font-subheading: 'sofia-pro', 'Outfit', sans-serif;
    --font-body:       'acumin-pro', 'Outfit', sans-serif;
  }

  h1, h2, h3, h4, h5, h6 { font-family: var(--font-heading); font-weight: 600; font-style: italic; }

  body {
    min-height: 100vh;
    background: var(--bg);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-body);
    font-weight: 500;
    color: var(--text);
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background: radial-gradient(ellipse 60% 50% at 50% 40%, rgba(224,36,52,.10) 0%, transparent 70%);
    pointer-events: none;
  }

  .card {
    width: 100%;
    max-width: 480px;
    padding: 56px 48px 48px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 20px;
    box-shadow: 0 32px 80px rgba(0,0,0,.8);
    animation: fadeUp .5s ease both;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .logo {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 3.2rem;
    letter-spacing: .06em;
    text-align: center;
    line-height: 1;
    margin-bottom: 10px;
    text-transform: uppercase;
    color: var(--text);
  }

  .subtitle {
    font-family: var(--font-subheading);
    font-weight: 700;
    text-align: center;
    font-size: 1.05rem;
    color: #d4d4d6;
    margin-bottom: 32px;
    letter-spacing: .02em;
  }

  .alert-danger {
    background: rgba(255,90,0,.12);
    border: 1px solid rgba(255,90,0,.4);
    border-radius: 10px;
    color: var(--orange);
    padding: 12px 16px;
    margin-bottom: 20px;
    font-size: .9rem;
    font-weight: 500;
  }

  .field { margin-bottom: 16px; }

  .field label {
    display: block;
    font-size: .82rem;
    color: var(--muted);
    font-weight: 600;
    margin-bottom: 6px;
    text-transform: uppercase;
    letter-spacing: .05em;
  }

  .input-wrap { position: relative; }

  .input-wrap input {
    width: 100%;
    background: var(--input-bg);
    border: 1.5px solid transparent;
    border-radius: 10px;
    color: var(--text);
    font-family: var(--font-body);
    font-size: .95rem;
    font-weight: 500;
    padding: 16px 48px 16px 18px;
    outline: none;
    transition: border-color .2s, box-shadow .2s;
  }

  .input-wrap input::placeholder { color: var(--muted); }

  .input-wrap input:focus {
    border-color: var(--orange);
    box-shadow: 0 0 0 3px rgba(255,90,0,.20);
  }

  .field-error {
    color: #e02434;
    font-size: .82rem;
    margin-top: 6px;
  }

  .toggle-pw {
    position: absolute;
    right: 16px;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    cursor: pointer;
    color: var(--muted);
    display: flex;
    align-items: center;
    transition: color .2s;
  }
  .toggle-pw:hover { color: var(--text); }

  .btn-primary {
    width: 100%;
    background: var(--orange);
    border: none;
    border-radius: 10px;
    color: #fff;
    font-family: var(--font-subheading);
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: .05em;
    text-transform: uppercase;
    padding: 17px;
    cursor: pointer;
    transition: background .2s, transform .1s, box-shadow .2s;
    box-shadow: 0 4px 20px rgba(255,90,0,.35);
    margin-top: 8px;
  }

  .btn-primary:hover { background: var(--orange-h); box-shadow: 0 6px 28px rgba(255,90,0,.5); }
  .btn-primary:active { transform: scale(.98); }
</style>
{% endblock %}

{% block body %}
  {% block navbar %}{% endblock %}

  <div class="card">
    <div class="logo">TrackStar</div>
    <p class="subtitle">Neues Passwort setzen</p>

    {% for msg in app.flashes('error') %}
      <div class="alert-danger">{{ msg }}</div>
    {% endfor %}

    {{ form_start(form) }}

      <div class="field">
        {{ form_label(form.newPassword) }}
        <div class="input-wrap">
          {{ form_widget(form.newPassword, { attr: { placeholder: 'Neues Passwort' } }) }}
          <button class="toggle-pw" type="button" onclick="togglePw(this)" aria-label="Passwort anzeigen">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
                fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/>
              <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/>
              <line x1="1" y1="1" x2="23" y2="23"/>
            </svg>
          </button>
        </div>
        {% if form.newPassword.vars.errors|length %}
          <div class="field-error">{{ form.newPassword.vars.errors[0].message }}</div>
        {% endif %}
      </div>

      <div class="field">
        {{ form_label(form.confirmPassword) }}
        <div class="input-wrap">
          {{ form_widget(form.confirmPassword, { attr: { placeholder: 'Passwort wiederholen' } }) }}
          <button class="toggle-pw" type="button" onclick="togglePw(this)" aria-label="Passwort anzeigen">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
                fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/>
              <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/>
              <line x1="1" y1="1" x2="23" y2="23"/>
            </svg>
          </button>
        </div>
        {% if form.confirmPassword.vars.errors|length %}
          <div class="field-error">{{ form.confirmPassword.vars.errors[0].message }}</div>
        {% endif %}
      </div>

      <button class="btn-primary" type="submit">Passwort speichern</button>

    {{ form_end(form) }}
  </div>

  <script>
    function togglePw(btn) {
      const input = btn.closest('.input-wrap').querySelector('input');
      const icon  = btn.querySelector('svg');
      const show  = input.type === 'password';
      input.type  = show ? 'text' : 'password';
      icon.innerHTML = show
        ? `<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>`
        : `<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/>
           <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/>
           <line x1="1" y1="1" x2="23" y2="23"/>`;
    }
  </script>
{% endblock %}
