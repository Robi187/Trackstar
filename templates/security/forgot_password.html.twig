{% extends 'base.html.twig' %}

{% block title %}Passwort vergessen – TrackStar{% endblock %}

{% block stylesheets %}
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
<style>
  @import url("https://use.typekit.net/tqp0iic.css");

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:        #000000;
    --surface:   #111113;
    --border:    #2a2a2d;
    --orange:    #ff5a00;
    --orange-h:  #ff7020;
    --text:      #ffffff;
    --muted:     #8a8a8e;
    --input-bg:  #3a3c41;
    --font-heading:    'futura-pt', 'Outfit', sans-serif;
    --font-subheading: 'sofia-pro', 'Outfit', sans-serif;
    --font-body:       'acumin-pro', 'Outfit', sans-serif;
  }

  h1, h2, h3, h4, h5, h6 { font-family: var(--font-heading); font-weight: 600; font-style: italic; }

  body {
    min-height: 100vh;
    background: var(--bg);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-body);
    font-weight: 500;
    color: var(--text);
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background: radial-gradient(ellipse 60% 50% at 50% 40%, rgba(224,36,52,.10) 0%, transparent 70%);
    pointer-events: none;
  }

  .card {
    width: 100%;
    max-width: 480px;
    padding: 56px 48px 48px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 20px;
    box-shadow: 0 32px 80px rgba(0,0,0,.8);
    animation: fadeUp .5s ease both;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .logo {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 3.2rem;
    letter-spacing: .06em;
    text-align: center;
    line-height: 1;
    margin-bottom: 10px;
    text-transform: uppercase;
    color: var(--text);
  }

  .subtitle {
    font-family: var(--font-subheading);
    font-weight: 700;
    text-align: center;
    font-size: 1.05rem;
    color: #d4d4d6;
    margin-bottom: 12px;
    letter-spacing: .02em;
  }

  .hint {
    text-align: center;
    font-family: var(--font-body);
    font-size: .88rem;
    color: var(--muted);
    margin-bottom: 32px;
    line-height: 1.5;
  }

  .field { margin-bottom: 16px; }

  .field input {
    width: 100%;
    background: var(--input-bg);
    border: 1.5px solid transparent;
    border-radius: 10px;
    color: var(--text);
    font-family: var(--font-body);
    font-size: .95rem;
    font-weight: 500;
    padding: 16px 18px;
    outline: none;
    transition: border-color .2s, box-shadow .2s;
  }

  .field input::placeholder { color: var(--muted); }

  .field input:focus {
    border-color: var(--orange);
    box-shadow: 0 0 0 3px rgba(255,90,0,.20);
  }

  .field input.has-error { border-color: #e02434; }

  .field-error {
    color: #e02434;
    font-size: .82rem;
    margin-top: 6px;
  }

  .btn-primary {
    width: 100%;
    background: var(--orange);
    border: none;
    border-radius: 10px;
    color: #fff;
    font-family: var(--font-subheading);
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: .05em;
    text-transform: uppercase;
    padding: 17px;
    cursor: pointer;
    transition: background .2s, transform .1s, box-shadow .2s;
    box-shadow: 0 4px 20px rgba(255,90,0,.35);
    margin-top: 8px;
  }

  .btn-primary:hover { background: var(--orange-h); box-shadow: 0 6px 28px rgba(255,90,0,.5); }
  .btn-primary:active { transform: scale(.98); }

  .back {
    display: block;
    text-align: center;
    color: var(--muted);
    font-family: var(--font-body);
    font-size: .88rem;
    text-decoration: none;
    margin-top: 24px;
    transition: color .2s;
  }
  .back:hover { color: var(--text); }

  .field-hint {
    font-size: .82rem;
    margin-top: 6px;
    min-height: 18px;
  }
  .field-hint.not-found { color: #e02434; }
  .field-hint.found { color: #4ade80; }
</style>
{% endblock %}

{% block body %}
  {% block navbar %}{% endblock %}

  <div class="card">
    <div class="logo">TrackStar</div>
    <p class="subtitle">Passwort vergessen?</p>
    <p class="hint">Gib deine E-Mail-Adresse ein und wir schicken dir einen Link zum Zurücksetzen.</p>

    <form method="post" novalidate>
      <div class="field">
        <input
          type="email"
          name="email"
          id="email-input"
          placeholder="deine@email.com"
          value="{{ emailInput ?? '' }}"
          class="{{ emailError ? 'has-error' : '' }}"
          autocomplete="email"
          autofocus
        />
        {% if emailError %}
          <div class="field-error">{{ emailError }}</div>
        {% else %}
          <div class="field-hint" id="email-hint"></div>
        {% endif %}
      </div>

      <button class="btn-primary" type="submit" id="submit-btn">Link senden</button>
    </form>

    <a href="{{ path('app_login') }}" class="back">← Zurück zum Login</a>
  </div>

<script>
  const input = document.getElementById('email-input');
  const hint  = document.getElementById('email-hint');
  const btn   = document.getElementById('submit-btn');

  if (input && hint) {
    let timer;

    btn.disabled = true;
    btn.style.opacity = '0.4';
    btn.style.cursor = 'not-allowed';

    input.addEventListener('input', () => {
      clearTimeout(timer);
      const val = input.value.trim();

      btn.disabled = true;
      btn.style.opacity = '0.4';
      btn.style.cursor = 'not-allowed';
      hint.textContent = '';
      hint.className = 'field-hint';

      if (!val || !val.includes('@')) return;

      timer = setTimeout(async () => {
        const res  = await fetch('/check-email?email=' + encodeURIComponent(val));
        const data = await res.json();

        if (data.exists) {
          hint.textContent = 'E-Mail-Adresse gefunden.';
          hint.className = 'field-hint found';
          btn.disabled = false;
          btn.style.opacity = '1';
          btn.style.cursor = 'pointer';
        } else {
          hint.textContent = 'Kein Account mit dieser E-Mail-Adresse gefunden.';
          hint.className = 'field-hint not-found';
        }
      }, 400);
    });
  }
</script>
{% endblock %}
