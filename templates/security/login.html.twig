{% extends 'base.html.twig' %}

{% block title %}TrackStar – Login{% endblock %}

{% block stylesheets %}
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
<style>
  @import url('https://fonts.adobe.com/fonts/futura-pt');
  @import url('https://fonts.adobe.com/fonts/sofia-pro');
  @import url('https://fonts.adobe.com/fonts/acumin-pro');
  @import url("https://use.typekit.net/tqp0iic.css");

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:        #000000;
    --surface:   #111113;
    --border:    #2a2a2d;
    --orange:    #ff5a00;
    --orange-h:  #ff7020;
    --red:       #e02434;
    --text:      #ffffff;
    --muted:     #8a8a8e;
    --input-bg:  #3a3c41;

    --font-heading:    'futura-pt', 'Outfit', sans-serif;
    --font-subheading: 'sofia-pro', 'Outfit', sans-serif;
    --font-body:       'acumin-pro', 'Outfit', sans-serif;
    
  }

  h1, h2, h3, h4, h5, h6 {
  font-family: var(--font-heading);
  font-weight: 600;
  font-style: italic;
}

  body {
    min-height: 100vh;
    background: var(--bg);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-body);
    font-weight: 500;
    color: var(--text);
    overflow: hidden;
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background: radial-gradient(ellipse 60% 50% at 50% 40%, rgba(224,36,52,.10) 0%, transparent 70%);
    pointer-events: none;
  }

  .card {
    width: 100%;
    max-width: 480px;
    padding: 56px 48px 48px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 20px;
    box-shadow: 0 32px 80px rgba(0,0,0,.8);
    animation: fadeUp .5s ease both;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Überschrift – Futura PT Demi */
  .logo {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 3.2rem;
    letter-spacing: .06em;
    text-align: center;
    line-height: 1;
    margin-bottom: 10px;
    text-transform: uppercase;
    color: var(--text);
  }

  /* Unterüberschrift – Sofia Pro Bold */
  .subtitle {
    font-family: var(--font-subheading);
    font-weight: 700;
    text-align: center;
    font-size: 1.05rem;
    color: #d4d4d6;
    margin-bottom: 40px;
    letter-spacing: .02em;
  }

  .field {
    position: relative;
    margin-bottom: 16px;
  }

  /* Fließtext in Inputs – Acumin Pro Medium */
  .field input {
    width: 100%;
    background: var(--input-bg);
    border: 1.5px solid transparent;
    border-radius: 10px;
    color: var(--text);
    font-family: var(--font-body);
    font-size: .95rem;
    font-weight: 500;
    padding: 16px 48px 16px 18px;
    outline: none;
    transition: border-color .2s, box-shadow .2s;
  }

  .field input::placeholder { color: var(--muted); }

  .field input:focus {
    border-color: var(--orange);
    box-shadow: 0 0 0 3px rgba(224,36,52,.20);
  }

  .toggle-pw {
    position: absolute;
    right: 16px;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    cursor: pointer;
    color: var(--muted);
    display: flex;
    align-items: center;
    transition: color .2s;
  }
  .toggle-pw:hover { color: var(--text); }

  /* Fehlermeldung – Rot hervorheben */
  .alert-danger {
    background: rgba(224,36,52,.15);
    border: 1px solid rgba(224,36,52,.45);
    border-radius: 10px;
    color: var(--red);
    padding: 12px 16px;
    margin-bottom: 20px;
    font-family: var(--font-body);
    font-size: .9rem;
    font-weight: 500;
  }

  .forgot {
    display: block;
    text-align: center;
    color: var(--orange);
    font-family: var(--font-body);
    font-size: .88rem;
    font-weight: 500;
    text-decoration: none;
    margin: 4px 0 28px;
    transition: color .2s;
  }
  .forgot:hover { color: var(--orange); text-decoration: underline; }

  /* Button – Orange */
  .btn-primary {
    width: 100%;
    background: var(--orange);
    border: none;
    border-radius: 10px;
    color: #fff;
    font-family: var(--font-subheading);
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: .05em;
    text-transform: uppercase;
    padding: 17px;
    cursor: pointer;
    transition: background .2s, transform .1s, box-shadow .2s;
    box-shadow: 0 4px 20px rgba(255,90,0,.35);
  }
  .btn-primary:hover {
    background: var(--orange-h);
    box-shadow: 0 6px 28px rgba(255,90,0,.5);
  }
  .btn-primary:active { transform: scale(.98); }

  .divider {
    display: flex;
    align-items: center;
    gap: 14px;
    margin: 28px 0 20px;
  }
  .divider::before, .divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .register {
    text-align: center;
    font-family: var(--font-body);
    font-size: .92rem;
    color: var(--muted);
  }
  .register a {
    color: var(--orange);
    font-weight: 600;
    text-decoration: none;
    transition: color .2s;
  }
  .register a:hover { color: var(--orange-h); text-decoration: underline; }


  .flash-success {
    position: fixed;
    top: 20px;
    left: 37%;
    transform: translateX(-50%);
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(34, 197, 94, 0.15);
    border: 1px solid rgba(34, 197, 94, 0.45);
    border-radius: 8px;
    color: #4ade80;
    padding: 8px 14px;
    font-family: var(--font-body);
    font-size: .78rem;
    font-weight: 500;
    z-index: 999;
    white-space: nowrap;
    animation: fadeUp .4s ease both;
    transition: opacity .5s ease, transform .5s ease;
    margin-left: 
  }

  .flash-success.hide {
    opacity: 0;
    transform: translateX(-50%) translateY(-10px);
    pointer-events: none;
  }

  .flash-icon {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }
</style>
{% endblock %}

{% block body %}
    {% for msg in app.flashes('success') %}
      <div class="flash-success">
        <svg class="flash-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/><polyline points="9 12 11 14 15 10"/>
        </svg>
        {{ msg }}
      </div>
    {% endfor %}
<div class="card">
  <div class="logo">TrackStar</div>
  <p class="subtitle">Willkommen bei TrackStar!</p>

  <form method="post" novalidate>
    {% if error %}
      <div class="alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
    {% endif %}

    <div class="field">
      <input type="email"
             value="{{ last_username }}"
             name="_username"
             id="username"
             placeholder="E-Mail-Adresse oder Benutzername"
             autocomplete="email"
             required
             autofocus />
    </div>

    <div class="field">
      <input type="password"
             name="_password"
             id="password"
             placeholder="Passwort"
             autocomplete="current-password"
             required />
     <button class="toggle-pw" type="button" onclick="togglePassword()" aria-label="Passwort anzeigen">
      <svg id="eye-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
          fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/>
        <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/>
        <line x1="1" y1="1" x2="23" y2="23"/>
      </svg>
    </button>
    </div>

    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

    <a href="/passwort-vergessen" class="forgot">passwort vergessen?</a>

    <button class="btn-primary" type="submit">Anmelden</button>
  </form>

  <div class="divider"></div>

  <p class="register">
    Noch kein Konto? <a href="/register">Jetzt registrieren</a>
  </p>
</div>

<script>
  function togglePassword() {
    const pw = document.getElementById('password');
    const icon = document.getElementById('eye-icon');
    const show = pw.type === 'password';
    pw.type = show ? 'text' : 'password';
    icon.innerHTML = show
      ? `<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
        <circle cx="12" cy="12" r="3"/>`
      : `<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/>
        <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/>
        <line x1="1" y1="1" x2="23" y2="23"/>`;
  }

  const flash = document.querySelector('.flash-success');
  if (flash) {
    setTimeout(() => flash.classList.add('hide'), 3000);
    setTimeout(() => flash.remove(), 3500);
  }
</script>
{% endblock %}