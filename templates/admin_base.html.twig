{% extends 'base.html.twig' %}

{% block body %}
{{ parent() }}

<style>
    .admin-subnav {
        display: flex;
        align-items: center;
        gap: 4px;
        padding: 0 32px;
        height: 46px;
        background-color: #111111;
        border-bottom: 1px solid #2a2a2a;
    }

    .admin-subnav-item {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px 16px;
        border-radius: 6px;
        color: #666;
        text-decoration: none;
        font-size: 0.84rem;
        font-weight: 500;
        transition: all 0.18s;
        position: relative;
    }

    .admin-subnav-item:hover {
        color: #ccc;
        background: #1a1a1a;
    }

    .admin-subnav-item.active {
        color: #ffffff;
        background: #1a1a1a;
    }

    .admin-subnav-item.active::after {
        content: '';
        position: absolute;
        bottom: -1px;
        left: 16px;
        right: 16px;
        height: 2px;
        background: var(--orange);
        border-radius: 2px 2px 0 0;
    }

    .admin-subnav-item svg {
        width: 15px;
        height: 15px;
        fill: currentColor;
        flex-shrink: 0;
    }

    .admin-main {
        padding: 40px 40px 80px;
        max-width: 1300px;
        margin: 0 auto;
    }

    .admin-page-header {
        margin-bottom: 28px;
    }

    .admin-page-title {
        font-family: var(--font-heading);
        font-style: italic;
        font-size: 1.9rem;
        font-weight: 800;
        color: #ffffff;
        line-height: 1;
        margin-bottom: 6px;
    }

    .admin-page-subtitle {
        font-size: 14px;
        color: #888;
        line-height: 1.5;
    }

    /* ── ADMIN RESPONSIVE ── */
    @media (max-width: 1024px) {
        .admin-main {
            padding: 32px 24px 64px;
        }
        .admin-page-title {
            font-size: 1.6rem;
        }
    }

    @media (max-width: 768px) {
        .admin-subnav {
            padding: 0 14px;
            gap: 2px;
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
            scrollbar-width: none;
        }
        .admin-subnav::-webkit-scrollbar {
            display: none;
        }
        .admin-subnav-item {
            padding: 8px 12px;
            font-size: 0.8rem;
            white-space: nowrap;
            flex-shrink: 0;
        }
        .admin-subnav-item.active::after {
            left: 12px;
            right: 12px;
        }
        .admin-main {
            padding: 24px 14px 48px;
        }
        .admin-page-title {
            font-size: 1.4rem;
        }
        .admin-page-subtitle {
            font-size: 13px;
        }
    }

    @media (max-width: 480px) {
        .admin-subnav {
            padding: 0 10px;
        }
        .admin-subnav-item {
            padding: 8px 10px;
            font-size: 0.76rem;
        }
        .admin-main {
            padding: 18px 10px 32px;
        }
        .admin-page-title {
            font-size: 1.25rem;
        }
    }
</style>

<nav class="admin-subnav">
    <a href="{{ path('app_admin_users') }}"
       class="admin-subnav-item {{ app.request.pathinfo starts with '/admin/benutzer' or app.request.pathinfo starts with '/admin/users' ? 'active' : '' }}">
        <svg viewBox="0 0 24 24"><path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/></svg>
        Benutzerverwaltung
    </a>
    <a href="{{ path('app_admin_reports') }}"
       class="admin-subnav-item {{ app.request.pathinfo starts with '/admin/meldungen' or app.request.pathinfo starts with '/admin/reports' ? 'active' : '' }}">
        <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg>
        Meldungen
    </a>
</nav>

{% block admin_body %}{% endblock %}

{% endblock %}
