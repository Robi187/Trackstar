{% extends 'base.html.twig' %}

{% block title %}Deine Inhalte{% endblock %}

{% block body %}
{{ parent() }}

<style>
  .ku-page { display: flex; justify-content: center; align-items: flex-start; padding: 40px 20px; }
  .ku-wrap { display: flex; gap: 40px; align-items: flex-start; max-width: 1100px; width: 100%; }
  .ku-sidebar { width: 210px; min-width: 210px; background: #1a1a1a; border: 1.5px solid #3a3a3a; border-radius: 20px; padding: 28px 16px 20px; display: flex; flex-direction: column; gap: 6px; }
  .ku-avatar { width: 72px; height: 72px; border-radius: 14px; background: #2a2a2a; border: 1.5px solid #3a3a3a; display: flex; align-items: center; justify-content: center; margin: 0 auto 10px; }
  .ku-avatar svg { width: 36px; height: 36px; stroke: #aaa; fill: none; stroke-width: 1.5; }
  .ku-username { text-align: center; font-size: 15px; font-weight: 500; margin-bottom: 10px; color: #fff; }
  .ku-nav-btn { display: flex; align-items: center; gap: 10px; padding: 10px 14px; border-radius: 8px; font-size: 14px; font-weight: 400; cursor: pointer; border: 1px solid #3a3a3a; background: transparent; color: #ccc; width: 100%; text-align: left; text-decoration: none; box-sizing: border-box; }
  .ku-nav-btn.active { background: #e85d04; border-color: #e85d04; color: #fff; font-weight: 500; }
  .ku-nav-btn:hover:not(.active) { background: #2a2a2a; color: #fff; }
  .ku-nav-btn svg { width: 16px; height: 16px; stroke: currentColor; fill: none; stroke-width: 1.8; flex-shrink: 0; }
  .ku-divider { border: none; border-top: 1px solid #2a2a2a; margin: 6px 0; }
  .ku-nav-btn.danger { color: #e85d04; border: 1px solid #e85d04; }
  .ku-nav-btn.danger:hover { background: rgba(232,93,4,0.12); }
  .ku-main { flex: 1; padding-top: 4px; min-width: 0; }
  .ku-title { font-size: 26px; font-weight: 700; margin: 0 0 6px; color: #fff; }
  .ku-subtitle { font-size: 14px; color: #888; margin: 0 0 24px; line-height: 1.5; }
  .flash { display: flex; align-items: flex-start; gap: 10px; border-radius: 10px; padding: 13px 16px; margin-bottom: 16px; font-family: var(--font-body); font-size: .88rem; font-weight: 500; animation: flashIn .3s ease both; }
  .flash-success { background: rgba(0,200,80,.10); border: 1px solid rgba(0,200,80,.3); color: #00d966; }
  .flash-error { background: rgba(224,36,52,.12); border: 1px solid rgba(224,36,52,.4); color: #ff6070; }

  @keyframes flashIn {
    from { opacity: 0; transform: translateY(-6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

.content-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 20px;
}

.content-grid > .card {
  flex: 0 0 180px;
  width: 180px;
}

.card {
  position: relative; /* aus feature-branch */
  background: #1a1a1a;
  border-radius: 12px;
  overflow: hidden;
  cursor: pointer;
  transition: transform 0.2s, box-shadow 0.2s;
  border: 1px solid #2a2a2a;
}
  .card:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(0,0,0,0.4); }
  .card-actions { position: absolute; top: 10px; right: 10px; display: flex; gap: 8px; opacity: 0; pointer-events: none; transition: opacity 0.2s ease; z-index: 2; }
  .card:hover .card-actions { opacity: 1; pointer-events: auto; }
  .card-action { width: 34px; height: 34px; border-radius: 10px; background: rgba(0, 0, 0, 0.65); border: 1px solid rgba(255,255,255,0.1); color: #fff; display: inline-flex; align-items: center; justify-content: center; cursor: pointer; transition: background 0.2s ease; }
  .card-action:hover { background: rgba(232, 93, 4, 0.95); }
  .card-action svg { width: 16px; height: 16px; stroke: currentColor; fill: none; stroke-width: 1.8; }
  .card-action-edit:hover { background: rgba(68, 90, 115, 0.95); }
  .card-cover { width: 100%; aspect-ratio: 1 / 1; object-fit: cover; display: block; }
  .card-cover-placeholder { width: 100%; aspect-ratio: 1 / 1; background: #2a2a2a; display: flex; align-items: center; justify-content: center; font-size: 36px; }
  .card-body { padding: 10px 12px 12px; }
  .card-title { font-size: 14px; font-weight: 600; color: #fff; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-bottom: 4px; }
  .card-user { font-size: 12px; color: #888; margin-bottom: 8px; }
  .card-footer { display: flex; flex-wrap: wrap; gap: 4px; }
  .card-tag { background: #2a2a2a; color: #aaa; font-size: 11px; padding: 2px 8px; border-radius: 20px; }

  .empty-state { color: #666; font-size: 14px; }

  /* ── Responsive ── */
  @media (max-width: 860px) {
    .ku-wrap { flex-direction: column; gap: 20px; }
    .ku-sidebar { width: 100%; min-width: 0; padding: 20px; }
  }
  @media (max-width: 768px) {
    .ku-page { padding: 24px 14px; }
    .ku-title { font-size: 22px; }
    .content-grid { gap: 14px; }
    .content-grid > .card { flex: 0 0 150px; width: 150px; }
  }
  @media (max-width: 480px) {
    .ku-page { padding: 16px 10px; }
    .ku-sidebar { padding: 16px; border-radius: 14px; }
    .content-grid { gap: 10px; }
    .content-grid > .card { flex: 0 0 140px; width: 140px; }
  }
</style>

<div class="ku-page">
  <div class="ku-wrap">
    <div class="ku-sidebar">
      <div class="ku-avatar">
        <svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
      </div>
      <div class="ku-username">{{ user_data.getUsername() }}</div>

      <a href="{{ path('app_user_management') }}" class="ku-nav-btn">
        <svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
        Kontodetails
      </a>
      <a href="{{ path('app_deine_inhalte') }}" class="ku-nav-btn active">
        <svg viewBox="0 0 24 24"><path d="M12 16V4m0 0l-4 4m4-4l4 4"/><path d="M4 20h16"/></svg>
        Meine Uploads
      </a>
      <a href="{{ path('app_favorites') }}" class="ku-nav-btn">
        <svg viewBox="0 0 24 24"><path d="M12 21C12 21 3 14 3 8a5 5 0 0 1 9-3 5 5 0 0 1 9 3c0 6-9 13-9 13z"/></svg>
        Meine Favoriten
      </a>

      <hr class="ku-divider">

      <button class="ku-nav-btn">
        <svg viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        Abmelden
      </button>
      <button class="ku-nav-btn danger">
        <svg viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6m4-6v6"/><path d="M9 6V4h6v2"/></svg>
        Konto Löschen
      </button>
    </div>

    <div class="ku-main">
      <h1 class="ku-title">Deine Inhalte</h1>
      <p class="ku-subtitle">Hier werden deine hochgeladenen Inhalte angezeigt</p>

      {% for label, messages in app.flashes %}
        <div class="flash flash-{{ label }}">
          {% for message in messages %}
            <div>{{ message }}</div>
          {% endfor %}
        </div>
      {% endfor %}

      {% if contents is defined and contents|length > 0 %}
        <div class="content-grid">
          {% for content in contents %}

            <div class="card" onclick="window.location.href='/content/{{ content.id }}'">
              <div class="card-actions" onclick="event.stopPropagation()">
                <a href="{{ path('app_content_edit', {'id': content.id}) }}" class="card-action card-action-edit" title="Bearbeiten" aria-label="Bearbeiten">
                  <svg viewBox="0 0 24 24"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19.999H4v-3L16.5 3.5Z"/></svg>
                </a>
                <form method="post" action="{{ path('app_content_delete', {'id': content.id}) }}" onsubmit="event.stopPropagation(); return confirm('Möchtest du diesen Inhalt wirklich löschen?');">
                  <button type="submit" class="card-action" title="Löschen" aria-label="Löschen">
                    <svg viewBox="0 0 24 24"><path d="M3 6h18"/><path d="M8 6V4h8v2"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/></svg>
                  </button>
                </form>
              </div>

              {% if content.imageFile %}
                <img
                  class="card-cover"
                  src="{{ asset(content.imageFile) }}"
                  alt="{{ content.title }}"
                  loading="lazy"
                />
              {% else %}
                <div class="card-cover-placeholder">🎵</div>
              {% endif %}

              <div class="card-body">
                <div class="card-title" title="{{ content.title }}">{{ content.title }}</div>
                {% if content.fkUser.username %}
                  <div class="card-user">{{ content.fkUser.username }}</div>
                {% endif %}
                <div class="card-footer">
                    {% for tag in tagsByContent[content.id] %}
                        <div class="card-tag">{{ tag.fkTag.name }}</div>
                    {% endfor %}
                </div>
                <div class="card-stats">
                    {% if ratingsByContent[content.id] is defined %}
                    <span class="card-stat" style="color:var(--orange)">&#9733; {{ ratingsByContent[content.id]|number_format(1) }}</span>
                    {% endif %}
                    {% if content.downloadCount is defined and content.downloadCount > 0 %}
                    <span class="card-stat">
                        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"/></svg>
                        {{ content.downloadCount }}
                    </span>
                    {% endif %}
                </div>
              </div>

            </div>
          {% endfor %}
        </div>
      {% else %}
        <p class="empty-state">Du hast noch keine Inhalte hochgeladen.</p>
      {% endif %}
    </div>

  </div>
</div>
{% endblock %}