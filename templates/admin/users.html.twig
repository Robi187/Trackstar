{% extends 'admin_base.html.twig' %}

{% block title %}Admin – Benutzerverwaltung{% endblock %}

{% block admin_body %}

<style>
  .ku-flash { display: flex; align-items: center; gap: 10px; border-radius: 10px; padding: 13px 16px; margin-bottom: 16px; font-size: .88rem; font-weight: 500; }
  .ku-flash svg { flex-shrink: 0; width: 18px; height: 18px; }
  .ku-flash.success { background: rgba(0,200,80,.10); border: 1px solid rgba(0,200,80,.3); color: #00d966; }
  .ku-flash.error   { background: rgba(224,36,52,.12); border: 1px solid rgba(224,36,52,.4); color: #ff6070; }

  .stat-row { display: flex; gap: 16px; margin-bottom: 24px; }
  .stat-box { background: #1e1e1e; border: 1px solid #2a2a2a; border-radius: 12px; padding: 16px 20px; flex: 1; }
  .stat-box .stat-val { font-size: 28px; font-weight: 700; color: #fff; }
  .stat-box .stat-lbl { font-size: 12px; color: #666; margin-top: 2px; }

  .admin-card { background: #1e1e1e; border-radius: 14px; overflow: hidden; border: 1px solid #2a2a2a; }
  .admin-table { width: 100%; border-collapse: collapse; font-size: 14px; }
  .admin-table thead { background: #161616; }
  .admin-table th { padding: 13px 16px; text-align: left; font-size: 12px; font-weight: 600; color: #666; text-transform: uppercase; letter-spacing: 0.06em; border-bottom: 1px solid #2a2a2a; }
  .admin-table td { padding: 13px 16px; border-bottom: 1px solid #222; color: #ccc; vertical-align: middle; }
  .admin-table tbody tr:last-child td { border-bottom: none; }
  .admin-table tbody tr:hover td { background: #232323; }

  .user-cell { display: flex; align-items: center; gap: 10px; }
  .user-initial { width: 32px; height: 32px; border-radius: 8px; background: #2a2a2a; border: 1px solid #3a3a3a; display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 600; color: #aaa; flex-shrink: 0; text-transform: uppercase; }
  .user-name { font-weight: 500; color: #fff; }

  .role-badge { display: inline-block; padding: 2px 8px; border-radius: 5px; font-size: 11px; font-weight: 600; letter-spacing: 0.04em; }
  .role-admin { background: rgba(232,93,4,.18); color: #e85d04; border: 1px solid rgba(232,93,4,.35); }
  .role-user  { background: rgba(255,255,255,.06); color: #888; border: 1px solid #333; }

  .status-badge  { display: inline-block; padding: 2px 8px; border-radius: 5px; font-size: 11px; font-weight: 600; }
  .status-active { background: rgba(0,200,80,.10); color: #00d966; border: 1px solid rgba(0,200,80,.3); }
  .status-banned { background: rgba(224,36,52,.12); color: #ff6070; border: 1px solid rgba(224,36,52,.4); }

  .action-wrap      { display: flex; align-items: center; gap: 6px; }
  .action-wrap form { display: flex; align-items: center; }

  .btn-action { display: inline-flex; align-items: center; justify-content: center; gap: 6px; padding: 7px 12px; border-radius: 8px; font-size: 12px; font-weight: 500; cursor: pointer; font-family: inherit; transition: background .2s, border-color .2s, color .2s, box-shadow .2s; white-space: nowrap; border: none; }
  .btn-action svg { width: 14px; height: 14px; stroke: currentColor; fill: none; stroke-width: 2.2; flex-shrink: 0; }
  .btn-delete { border: 1px solid rgba(224,36,52,.4); color: #ff6070; background: rgba(224,36,52,.08); }
  .btn-delete:hover { background: rgba(200,40,30,0.18); border-color: #cc3322; color: #ff5544; box-shadow: 0 0 10px rgba(200,40,30,0.15); }
  .btn-ban    { border: 1px solid rgba(232,93,4,.4); color: #e85d04; background: rgba(232,93,4,.08); }
  .btn-ban:hover { background: rgba(232,93,4,0.18); border-color: #e85d04; color: #ff7722; box-shadow: 0 0 10px rgba(232,93,4,0.15); }
  .btn-unban  { border: 1px solid rgba(0,200,80,.3); color: #00d966; background: rgba(0,200,80,.08); }
  .btn-unban:hover { background: rgba(0,200,80,0.18); border-color: #00d966; color: #00ff77; box-shadow: 0 0 10px rgba(0,200,80,0.12); }
  .self-badge { font-size: 12px; color: #555; font-style: italic; }

  /* Ban Modal */
  .ban-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.7); backdrop-filter: blur(4px); z-index: 1000; align-items: center; justify-content: center; }
  .ban-overlay.open { display: flex; }
  .ban-modal { background: #1a1a1a; border: 1px solid #2e2e2e; border-radius: 16px; padding: 28px; width: 360px; box-shadow: 0 24px 60px rgba(0,0,0,0.6); animation: modalIn .2s ease; }
  @keyframes modalIn { from { opacity: 0; transform: translateY(-12px) scale(0.97); } to { opacity: 1; transform: translateY(0) scale(1); } }
  .ban-modal-title { font-size: 16px; font-weight: 700; color: #fff; margin: 0 0 4px; }
  .ban-modal-sub   { font-size: 13px; color: #666; margin: 0 0 20px; }
  .ban-modal-sub strong { color: #aaa; }
  .ban-modal-label { font-size: 11px; color: #555; margin-bottom: 8px; display: block; letter-spacing: 0.06em; text-transform: uppercase; }
  .ban-modal-options { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 16px; }
  .ban-opt { padding: 10px; border-radius: 8px; border: 1px solid #2c2c2c; background: #141414; color: #888; font-size: 13px; font-weight: 500; cursor: pointer; text-align: center; transition: all .15s; font-family: inherit; }
  .ban-opt:hover, .ban-opt.selected { border-color: #e85d04; color: #e85d04; background: rgba(232,93,4,0.08); }
  .ban-custom-row { display: flex; gap: 8px; margin-bottom: 20px; }
  .ban-custom-input { flex: 1; background: #141414; border: 1px solid #2c2c2c; border-radius: 8px; color: #fff; font-size: 13px; padding: 9px 12px; outline: none; font-family: inherit; transition: border-color .15s; }
  .ban-custom-input:focus { border-color: #e85d04; }
  .ban-custom-unit { appearance: none; background: #141414; border: 1px solid #2c2c2c; border-radius: 8px; color: #888; font-size: 13px; padding: 9px 12px; outline: none; font-family: inherit; cursor: pointer; }
  .ban-modal-actions { display: flex; gap: 8px; }
  .ban-modal-cancel  { flex: 1; padding: 10px; border-radius: 8px; border: 1px solid #2c2c2c; background: transparent; color: #666; font-size: 13px; font-weight: 500; cursor: pointer; font-family: inherit; transition: all .15s; }
  .ban-modal-cancel:hover { border-color: #444; color: #aaa; }
  .ban-modal-confirm { flex: 1; padding: 10px; border-radius: 8px; border: 1px solid rgba(232,93,4,.5); background: rgba(232,93,4,0.12); color: #e85d04; font-size: 13px; font-weight: 600; cursor: pointer; font-family: inherit; transition: all .15s; }
  .ban-modal-confirm:hover { background: rgba(232,93,4,0.22); border-color: #e85d04; color: #ff7722; box-shadow: 0 0 12px rgba(232,93,4,0.2); }
</style>

<div class="admin-main">

  <div class="admin-page-header">
    <h1 class="admin-page-title">Benutzerverwaltung</h1>
    <p class="admin-page-subtitle">Übersicht aller registrierten Benutzer. Konten sperren oder löschen.</p>
  </div>

  {% for msg in app.flashes('success') %}
    <div class="ku-flash success">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><circle cx="12" cy="12" r="10"/><polyline points="9 12 11 14 15 10"/></svg>
      {{ msg }}
    </div>
  {% endfor %}
  {% for msg in app.flashes('error') %}
    <div class="ku-flash error">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      {{ msg }}
    </div>
  {% endfor %}

  <div class="stat-row">
    <div class="stat-box">
      <div class="stat-val">{{ users|length }}</div>
      <div class="stat-lbl">Registrierte Benutzer</div>
    </div>
    <div class="stat-box">
      <div class="stat-val">{{ users|filter(u => 'ROLE_ADMIN' in u.roles)|length }}</div>
      <div class="stat-lbl">Administratoren</div>
    </div>
    <div class="stat-box">
      <div class="stat-val">{{ users|filter(u => u.isBanned())|length }}</div>
      <div class="stat-lbl">Gesperrte Benutzer</div>
    </div>
  </div>

  <div class="admin-card">
    <table class="admin-table">
      <thead>
        <tr>
          <th>#</th>
          <th>Benutzername</th>
          <th>E-Mail</th>
          <th>Rolle</th>
          <th>Status</th>
          <th>Registriert</th>
          <th>Aktionen</th>
        </tr>
      </thead>
      <tbody>
        {% for u in users %}
        <tr>
          <td style="color:#555">{{ u.id }}</td>
          <td>
            <div class="user-cell">
              <div class="user-initial">{{ u.username|slice(0,1) }}</div>
              <span class="user-name">
                {{ u.username }}
                {% if u.id == app.user.id %}<span style="color:#555;font-size:11px;font-weight:400"> (du)</span>{% endif %}
              </span>
            </div>
          </td>
          <td>{{ u.email }}</td>
          <td>
            {% if 'ROLE_ADMIN' in u.roles %}
              <span class="role-badge role-admin">Admin</span>
            {% else %}
              <span class="role-badge role-user">User</span>
            {% endif %}
          </td>
          <td>
            {% if u.isBanned() %}
              <span class="status-badge status-banned" title="Gesperrt bis {{ u.bannedUntil|date('d.m.Y H:i') }}">
                Gesperrt bis {{ u.bannedUntil|date('d.m.Y') }}
              </span>
            {% else %}
              <span class="status-badge status-active">Aktiv</span>
            {% endif %}
          </td>
          <td>{{ u.createdAt ? u.createdAt|date('d.m.Y') : '–' }}</td>
          <td>
            {% if u.id == app.user.id %}
              <span class="self-badge">eigenes Konto</span>
            {% else %}
              <div class="action-wrap">
                {% if u.isBanned() %}
                  <form method="post" action="{{ path('app_admin_unban_user', {id: u.id}) }}"
                        onsubmit="return confirm('Sperre für „{{ u.username }}" aufheben?')">
                    <button type="submit" class="btn-action btn-unban" title="Entsperren">
                      <svg viewBox="0 0 24 24"><path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="10"/></svg>
                    </button>
                  </form>
                {% else %}
                  <button type="button" class="btn-action btn-ban" title="Sperren"
                          onclick="openBanModal('{{ u.id }}', '{{ u.username|e('js') }}')">
                    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
                  </button>
                {% endif %}
                <form method="post" action="{{ path('app_admin_delete_user', {id: u.id}) }}"
                      onsubmit="return confirm('Benutzer „{{ u.username }}" wirklich löschen? Diese Aktion kann nicht rückgängig gemacht werden.')">
                  <button type="submit" class="btn-action btn-delete" title="Löschen">
                    <svg viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6m4-6v6"/><path d="M9 6V4h6v2"/></svg>
                  </button>
                </form>
              </div>
            {% endif %}
          </td>
        </tr>
        {% else %}
        <tr>
          <td colspan="7" style="text-align:center;color:#555;padding:32px">Keine Benutzer gefunden.</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

</div>

{# Ban Modal #}
<div class="ban-overlay" id="banOverlay" onclick="closeBanModal(event)">
  <div class="ban-modal">
    <div class="ban-modal-title">Benutzer sperren</div>
    <div class="ban-modal-sub">Wie lange soll <strong id="banUsername"></strong> gesperrt werden?</div>
    <span class="ban-modal-label">Schnellauswahl</span>
    <div class="ban-modal-options">
      <button class="ban-opt" onclick="selectDuration('1 day', this)">1 Tag</button>
      <button class="ban-opt" onclick="selectDuration('3 days', this)">3 Tage</button>
      <button class="ban-opt selected" onclick="selectDuration('7 days', this)">7 Tage</button>
      <button class="ban-opt" onclick="selectDuration('30 days', this)">30 Tage</button>
      <button class="ban-opt" onclick="selectDuration('90 days', this)">3 Monate</button>
      <button class="ban-opt" onclick="selectDuration('365 days', this)">1 Jahr</button>
    </div>
    <span class="ban-modal-label">Oder eigene Dauer</span>
    <div class="ban-custom-row">
      <input type="number" class="ban-custom-input" id="banCustomNum" min="1" max="9999" placeholder="z. B. 14" oninput="clearPreset()" />
      <select class="ban-custom-unit" id="banCustomUnit" onchange="clearPreset()">
        <option value="days">Tage</option>
        <option value="weeks">Wochen</option>
        <option value="months">Monate</option>
      </select>
    </div>
    <div class="ban-modal-actions">
      <button class="ban-modal-cancel" onclick="closeBanModalDirect()">Abbrechen</button>
      <form method="post" id="banForm" action="" style="flex:1;display:flex;">
        <input type="hidden" name="duration" id="banDurationInput" value="7 days" />
        <button type="submit" class="ban-modal-confirm" style="width:100%">Sperren</button>
      </form>
    </div>
  </div>
</div>

<script>
  function openBanModal(userId, username) {
    document.getElementById('banUsername').textContent = username;
    document.getElementById('banForm').action = '{{ path('app_admin_ban_user', {id: '__ID__'}) }}'.replace('__ID__', userId);
    document.getElementById('banOverlay').classList.add('open');
    document.getElementById('banDurationInput').value = '7 days';
    document.getElementById('banCustomNum').value = '';
    document.querySelectorAll('.ban-opt').forEach((b, i) => b.classList.toggle('selected', i === 2));
  }
  function closeBanModal(e) { if (e.target === document.getElementById('banOverlay')) closeBanModalDirect(); }
  function closeBanModalDirect() { document.getElementById('banOverlay').classList.remove('open'); }
  function selectDuration(val, el) {
    document.getElementById('banDurationInput').value = val;
    document.getElementById('banCustomNum').value = '';
    document.querySelectorAll('.ban-opt').forEach(b => b.classList.remove('selected'));
    el.classList.add('selected');
  }
  function clearPreset() {
    document.querySelectorAll('.ban-opt').forEach(b => b.classList.remove('selected'));
    const num = document.getElementById('banCustomNum').value;
    const unit = document.getElementById('banCustomUnit').value;
    if (num) document.getElementById('banDurationInput').value = num + ' ' + unit;
  }
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeBanModalDirect(); });
</script>

{% endblock %}
