{% extends 'base.html.twig' %}

{% block title %}Admin – Benutzerverwaltung{% endblock %}

{% block body %}
{{ parent() }}

<style>
  .ku-back { display: flex; align-items: center; gap: 6px; font-size: 13px; color: #888; text-decoration: none; margin-bottom: 4px; }
  .ku-back:hover { color: #fff; }
  .ku-page { display: flex; justify-content: center; align-items: flex-start; padding: 40px 20px; }
  .ku-wrap { display: flex; gap: 40px; align-items: flex-start; max-width: 1100px; width: 100%; }
  .ku-sidebar { width: 210px; min-width: 210px; background: #1a1a1a; border: 1.5px solid #3a3a3a; border-radius: 20px; padding: 28px 16px 20px; display: flex; flex-direction: column; gap: 6px; }
  .ku-avatar { width: 72px; height: 72px; border-radius: 14px; background: #2a2a2a; border: 1.5px solid #3a3a3a; display: flex; align-items: center; justify-content: center; margin: 0 auto 10px; }
  .ku-avatar svg { width: 36px; height: 36px; stroke: #aaa; fill: none; stroke-width: 1.5; }
  .ku-username { text-align: center; font-size: 15px; font-weight: 500; margin-bottom: 10px; color: #fff; }
  .ku-nav-btn { display: flex; align-items: center; gap: 10px; padding: 10px 14px; border-radius: 8px; font-size: 14px; font-weight: 400; cursor: pointer; border: 1px solid #3a3a3a; background: transparent; color: #ccc; width: 100%; text-align: left; text-decoration: none; box-sizing: border-box; }
  .ku-nav-btn.active { background: #e85d04; border-color: #e85d04; color: #fff; font-weight: 500; }
  .ku-nav-btn:hover:not(.active) { background: #2a2a2a; color: #fff; }
  .ku-nav-btn svg { width: 16px; height: 16px; stroke: currentColor; fill: none; stroke-width: 1.8; flex-shrink: 0; }
  .ku-divider { border: none; border-top: 1px solid #2a2a2a; margin: 6px 0; }
  .ku-main { flex: 1; padding-top: 4px; min-width: 0; }
  .ku-title { font-size: 26px; font-weight: 700; margin: 0 0 6px; color: #fff; }
  .ku-subtitle { font-size: 14px; color: #888; margin: 0 0 24px; line-height: 1.5; }
  .ku-flash { display: flex; align-items: center; gap: 10px; border-radius: 10px; padding: 13px 16px; margin-bottom: 16px; font-size: .88rem; font-weight: 500; }
  .ku-flash svg { flex-shrink: 0; width: 18px; height: 18px; }
  .ku-flash.success { background: rgba(0,200,80,.10); border: 1px solid rgba(0,200,80,.3); color: #00d966; }
  .ku-flash.error { background: rgba(224,36,52,.12); border: 1px solid rgba(224,36,52,.4); color: #ff6070; }

  /* Admin table */
  .admin-card { background: #1e1e1e; border-radius: 14px; overflow: hidden; border: 1px solid #2a2a2a; }
  .admin-table { width: 100%; border-collapse: collapse; font-size: 14px; }
  .admin-table thead { background: #161616; }
  .admin-table th { padding: 13px 16px; text-align: left; font-size: 12px; font-weight: 600; color: #666; text-transform: uppercase; letter-spacing: 0.06em; border-bottom: 1px solid #2a2a2a; }
  .admin-table td { padding: 13px 16px; border-bottom: 1px solid #222; color: #ccc; vertical-align: middle; }
  .admin-table tbody tr:last-child td { border-bottom: none; }
  .admin-table tbody tr:hover td { background: #232323; }
  .user-cell { display: flex; align-items: center; gap: 10px; }
  .user-initial { width: 32px; height: 32px; border-radius: 8px; background: #2a2a2a; border: 1px solid #3a3a3a; display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 600; color: #aaa; flex-shrink: 0; text-transform: uppercase; }
  .user-name { font-weight: 500; color: #fff; }
  .role-badge { display: inline-block; padding: 2px 8px; border-radius: 5px; font-size: 11px; font-weight: 600; letter-spacing: 0.04em; }
  .role-admin { background: rgba(232,93,4,.18); color: #e85d04; border: 1px solid rgba(232,93,4,.35); }
  .role-user  { background: rgba(255,255,255,.06); color: #888; border: 1px solid #333; }
  .delete-form button {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 5px 12px; border-radius: 7px; font-size: 12px; font-weight: 500;
    border: 1px solid rgba(224,36,52,.4); color: #ff6070; background: rgba(224,36,52,.08);
    cursor: pointer; font-family: inherit; transition: background .15s, border-color .15s;
  }
  .delete-form button:hover { background: rgba(224,36,52,.18); border-color: #e02434; }
  .delete-form button svg { width: 13px; height: 13px; stroke: currentColor; fill: none; stroke-width: 2; }
  .self-badge { font-size: 12px; color: #555; font-style: italic; }
  .stat-row { display: flex; gap: 20px; margin-bottom: 20px; }
  .stat-box { background: #1e1e1e; border: 1px solid #2a2a2a; border-radius: 12px; padding: 16px 20px; flex: 1; }
  .stat-box .stat-val { font-size: 28px; font-weight: 700; color: #fff; }
  .stat-box .stat-lbl { font-size: 12px; color: #666; margin-top: 2px; }
</style>

<div class="ku-page">
  <div class="ku-wrap">

    <!-- Sidebar -->
    <div class="ku-sidebar">
      <div class="ku-avatar">
        <svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
      </div>
      <div class="ku-username">{{ user_data.username }}</div>

      <a href="{{ path('app_user_management') }}" class="ku-nav-btn">
        <svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
        Kontodetails
      </a>
      <a href="{{ path('app_deine_inhalte') }}" class="ku-nav-btn">
        <svg viewBox="0 0 24 24"><path d="M12 16V4m0 0l-4 4m4-4l4 4"/><path d="M4 20h16"/></svg>
        Meine Uploads
      </a>
      <a href="{{ path('app_favorites') }}" class="ku-nav-btn">
        <svg viewBox="0 0 24 24"><path d="M12 21C12 21 3 14 3 8a5 5 0 0 1 9-3 5 5 0 0 1 9 3c0 6-9 13-9 13z"/></svg>
        Meine Favoriten
      </a>

      <hr class="ku-divider">

      <a href="{{ path('app_admin_users') }}" class="ku-nav-btn active">
        <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        Benutzerverwaltung
      </a>

      <hr class="ku-divider">

      <a href="/logout" class="ku-nav-btn">
        <svg viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        Abmelden
      </a>
    </div>

    <!-- Main -->
    <div class="ku-main">
      <h1 class="ku-title">Benutzerverwaltung</h1>
      <p class="ku-subtitle">Übersicht aller registrierten Benutzer. Administratoren können Konten löschen.</p>

      {% for msg in app.flashes('success') %}
        <div class="ku-flash success">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/><polyline points="9 12 11 14 15 10"/>
          </svg>
          {{ msg }}
        </div>
      {% endfor %}

      {% for msg in app.flashes('error') %}
        <div class="ku-flash error">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
          </svg>
          {{ msg }}
        </div>
      {% endfor %}

      <!-- Stats -->
      <div class="stat-row">
        <div class="stat-box">
          <div class="stat-val">{{ users|length }}</div>
          <div class="stat-lbl">Registrierte Benutzer</div>
        </div>
        <div class="stat-box">
          <div class="stat-val">{{ users|filter(u => 'ROLE_ADMIN' in u.roles)|length }}</div>
          <div class="stat-lbl">Administratoren</div>
        </div>
      </div>

      <!-- Table -->
      <div class="admin-card">
        <table class="admin-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Benutzername</th>
              <th>E-Mail</th>
              <th>Rolle</th>
              <th>Registriert</th>
              <th>Aktionen</th>
            </tr>
          </thead>
          <tbody>
            {% for u in users %}
            <tr>
              <td style="color:#555">{{ u.id }}</td>
              <td>
                <div class="user-cell">
                  <div class="user-initial">{{ u.username|slice(0,1) }}</div>
                  <span class="user-name">
                    {{ u.username }}
                    {% if u.id == app.user.id %}<span style="color:#555;font-size:11px;font-weight:400"> (du)</span>{% endif %}
                  </span>
                </div>
              </td>
              <td>{{ u.email }}</td>
              <td>
                {% if 'ROLE_ADMIN' in u.roles %}
                  <span class="role-badge role-admin">Admin</span>
                {% else %}
                  <span class="role-badge role-user">User</span>
                {% endif %}
              </td>
              <td>{{ u.createdAt ? u.createdAt|date('d.m.Y') : '–' }}</td>
              <td>
                {% if u.id == app.user.id %}
                  <span class="self-badge">eigenes Konto</span>
                {% else %}
                  <form class="delete-form" method="post"
                        action="{{ path('app_admin_delete_user', {id: u.id}) }}"
                        onsubmit="return confirm('Benutzer „{{ u.username }}" wirklich löschen? Diese Aktion kann nicht rückgängig gemacht werden.')">
                    <button type="submit">
                      <svg viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6m4-6v6"/><path d="M9 6V4h6v2"/></svg>
                      Löschen
                    </button>
                  </form>
                {% endif %}
              </td>
            </tr>
            {% else %}
            <tr>
              <td colspan="6" style="text-align:center;color:#555;padding:32px;">Keine Benutzer gefunden.</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>

    </div>
  </div>
</div>
{% endblock %}
