{% extends 'base.html.twig' %}

{% block title %}TrackStar{% endblock %}

{% block body %}
{{ parent() }}

{# ── MAIN CONTENT ── #}
<main class="main">
    <h1 class="section-title">{{ title }}</h1>

    {% if contents is defined and contents|length > 0 %}
        <div class="content-grid">
            {% for item in contents %}
                <div class="card" onclick="window.location.href='/content/{{ item.id }}'">

                    {# Cover Image #}
                    {% if item.image_path %}
                        <img
                            class="card-cover"
                            src="{{ asset(item.image_path) }}"
                            alt="{{ item.title }}"
                            loading="lazy"
                        />
                    {% else %}
                        <div class="card-cover-placeholder">&#127925;</div>
                    {% endif %}

                    <div class="card-body">

                        {# Title #}
                        <div class="card-title" title="{{ item.title }}">
                            {{ item.title }}
                        </div>

                        {# Producer / User #}
                        {% if item.user %}
                            <div class="card-user">{{ item.user }}</div>
                        {% endif %}

                        <div class="card-footer">
                            {% if tagsByContent[item.id] is defined %}
                                {% for tag in tagsByContent[item.id] %}
                                    <span class="card-tag">{{ tag.fkTag.name }}</span>
                                {% endfor %}
                            {% endif %}
                        </div>
                        <div class="card-stats">
                            {% if ratingsByContent[item.id] is defined %}
                            <span class="card-stat" style="color:var(--orange)">&#9733; {{ ratingsByContent[item.id]|number_format(1) }}</span>
                            {% endif %}
                            {% if item.download_count is defined and item.download_count > 0 %}
                            <span class="card-stat">
                                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"/></svg>
                                {{ item.download_count }}
                            </span>
                            {% endif %}
                        </div>

                    </div>
                </div>
            {% endfor %}
        </div>

    {% else %}
        <div class="empty-state">
            Noch keine Inhalte verfügbar.
        </div>
    {% endif %}

</main>
{% endblock %}
