{% block body %}
{{ parent() }}

{# ── MAIN CONTENT ── #}
<main class="main">
    <h1 class="section-title">Entdecke neue Musik</h1>

    {% if contents is defined and contents|length > 0 %}
        <div class="content-grid">
            {% for item in contents %}
                <div class="card" onclick="window.location.href='/content/{{ item.id }}'">

                    {# Cover Image #}
                    {% if item.image_path %}
                        <img
                            class="card-cover"
                            src="{{ asset(item.image_path) }}"
                            alt="{{ item.title }}"
                            loading="lazy"
                        />
                    {% else %}
                        <div class="card-cover-placeholder">&#127925;</div>
                    {% endif %}

                    <div class="card-body">

                        {# Title #}
                        <div class="card-title" title="{{ item.title }}">
                            {{ item.title }}
                        </div>

                        {# Producer / User #}
                        {% if item.user %}
                            <div class="card-user">{{ item.user }}</div>
                        {% endif %}

                        {# Footer: price badge + optional tag #}
                        <div class="card-footer">
                            {% if item.tag %}
                                <span class="card-tag">{{ item.tag }}</span>
                            {% endif %}
                        </div>

                    </div>
                </div>
            {% endfor %}
        </div>

    {% else %}
        <div class="empty-state">
            Noch keine Inhalte verfügbar.
        </div>
    {% endif %}

</main>
{% endblock %}
